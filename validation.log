+   check(availability, {
+     "availability 200 with calendar": function (r) {
+       if (r.status !== 200) return false;
+       try {
+         return r.json("availability") !== undefined;
+       } catch {
+         return false;
+       }
+     },
+   });
+   sleep(cfg.thinkTime);
+ 
+   const credit = http.get(cfg.baseUrl + "/api/member/credit-balance", {
+     headers: headers,
+     tags: tags,
+   });
+   check(credit, {
+     "credit balance 200": function (r) {
+       return r.status === 200;
+     },
+   });
+   sleep(cfg.thinkTime);
+ }
