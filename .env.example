# Database
DATABASE_URL=postgresql://tac:password@localhost:5432/tacbookings
DB_PASSWORD=password                   # Used by docker-compose for PostgreSQL
SHADOW_DATABASE_URL=                   # Optional. Used by `npm run db:check-drift` (and Prisma migrate dev) to replay migrations into a throwaway DB; leave empty outside CI/local drift checks

# NextAuth
NEXTAUTH_URL=http://localhost:3000
# Sign-in, 2FA, AND encryption of in-app provider credentials all derive from this
# secret. Use a strong value (>= 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating it drops all sessions, all 2FA enrolments/recovery codes, and all
# stored provider credentials — see DEPLOYMENT.md (auth-secret rotation runbook).
AUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_SECRET=your-secret-key-here-change-in-production  # Legacy fallback; keep aligned with AUTH_SECRET
AUTH_TRUST_HOST=true

# Operational defaults
CURRENCY=NZD
NEXT_PUBLIC_CURRENCY=NZD
TZ=Pacific/Auckland
NEXT_PUBLIC_TZ=Pacific/Auckland
LOCALE=en-NZ
NEXT_PUBLIC_LOCALE=en-NZ

# Optional modules are turned on or off entirely from the admin Modules page
# (Admin > Setup > Modules). There are no module feature-flag env vars.
NEXT_PUBLIC_GA_MEASUREMENT_ID=         # Optional GA4 measurement id. Analytics still requires Admin > Modules opt-in plus visitor consent.
# Google sign-in credentials are NO LONGER environment configuration (#2087).
# Enter and verify the per-club Google OAuth client id + secret in-app at
# Admin > Integrations > Google sign-in (encrypted at rest). Any GOOGLE_CLIENT_*
# env vars are ignored (detected + warned about) — re-enter in the wizard, then
# remove them.

# Local/staging seed admin. Required by `npm run db:seed`; choose your own values.
SEED_ADMIN_EMAIL=admin@example.org
SEED_ADMIN_PASSWORD=change-this-seed-password
# Optional display name for the seeded admin (defaults to "Admin User")
SEED_ADMIN_FIRST_NAME=
SEED_ADMIN_LAST_NAME=
SEED_LODGE_PASSWORD=change-this-lodge-kiosk-password

# Stripe
# Stripe CREDENTIALS (secret key, publishable key, webhook signing secret) are
# captured IN-APP now and stored encrypted in the database (Admin > Integrations
# > Stripe) — #2082. There are no STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET /
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY env vars any more; if any are still set they
# are IGNORED and flagged in setup readiness for removal (see CONFIGURATION.md and
# the DEPLOYMENT.md upgrade runbook). The publishable key is delivered to the
# browser at runtime from the store, so nothing Stripe is inlined at build time.

# Xero
# Xero CREDENTIALS (client id/secret, webhook key, the token-encryption key and
# the redirect URI) are captured IN-APP now and stored encrypted in the database
# (Admin > Integrations). There are no XERO_CLIENT_ID / XERO_CLIENT_SECRET /
# XERO_REDIRECT_URI / XERO_ENCRYPTION_KEY / XERO_WEBHOOK_KEY env vars any more —
# if any are still set they are IGNORED and flagged in setup readiness for
# removal (see CONFIGURATION.md and DEPLOYMENT.md upgrade runbook). The redirect
# URI derives from NEXTAUTH_URL. Only the operational tuning flags below remain:
XERO_ENABLE_DAILY_MEMBERSHIP_REFRESH=false
XERO_ENABLE_LIVE_MEMBER_GROUP_LOOKUPS=false
XERO_ENABLE_AUTOLOAD_XERO_CONTACT_GROUPS=false
# The finance dashboard reads Xero reports through this same operational connection.
# Reconnect Xero after deploying so the accounting.reports.read scope is granted.

# Email (AWS SES)
USE_AWS_SES=false        # MUST be "false" if USE_SMTP_RELAY is true
SMTP_HOST=email-smtp.ap-southeast-2.amazonaws.com
SMTP_PORT=587
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
SES_SNS_TOPIC_ARN=     # Required for SES bounce/complaint SNS webhook topic allowlisting
SES_SNS_ALLOW_UNSAFE_MISSING_TOPIC_ARN=false  # Local/dev only; never enable for deployed SES feedback ingestion
SES_SNS_ALLOW_SIGNATURE_V1=false  # Temporarily allow legacy SNS SignatureVersion 1 (SHA1); prefer SignatureVersion 2 on the topic

# Transactional Email System (external SMTP relay)
USE_SMTP_RELAY=false        # MUST be "false" if USE_AWS_SES is true
EMAIL_SERVER_HOST=smtp.example.org
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=smtp-user@example.org
EMAIL_SERVER_PASSWORD=

# Extra email Variables
# Email identity (from display name, support address, contact-form recipient) is
# admin-managed in Admin > Email Messages (DB-first EmailMessageSetting). EMAIL_FROM
# is the ONLY email env var besides transport secrets: it is the envelope /
# Return-Path sender and MUST be a provider-verified (SES) address in production.
EMAIL_FROM=bookings@example.org
BULK_SENDMAIL_LIMIT=1                  # Admin bulk communication sends allowed per hour

# Deployment
DOMAIN=example.org                    # Root public host used by Caddy for auto HTTPS and service subdomains
CRON_LEADER_RUNTIME_STATUS_URL=       # Optional internal URL for Admin > System Health to query the cron leader; Compose defaults to http://app:3000/api/deploy/runtime-status

# Addy address autocomplete (server-side proxy)
ADDY_API_KEY=
ADDY_API_SECRET=

# MiroTalk video meetings (calendar events). Base URL of your self-hosted
# MiroTalk instance; the join link is built server-side as <MIROTALK_URL>/join/<room>.
# Runtime setting (set + restart, no rebuild). Include the scheme; a bare host is
# assumed https. When unset it is DERIVED from the app's own domain (NEXTAUTH_URL)
# as https://meet.<domain> — so a prod deploy that forgets this points at a real
# same-domain host, not the clicker's machine; a loopback app host falls back to
# http://localhost:3010 for local dev. Set it explicitly if MiroTalk is on a
# different host, or if the app runs on a non-www subdomain.
MIROTALK_URL=                         # e.g. https://meet.example.org

# MiroTalk JWT access (optional — secure, login-free join links). Set all three
# to have the app append a short-lived signed ?token= to meeting links. Secrets;
# server-side only, never sent to the browser.
#  - MIRO_JWT_KEY must equal MiroTalk's own JWT_KEY.
#  - MIRO_MEETING_USERNAME/PASSWORD must match one entry in MiroTalk's HOST_USERS.
#  - MIRO_MEETING_PRESENTER=true (default) makes the clicker the host so the
#    meeting starts immediately; false leaves joiners on MiroTalk's
#    "waiting for host" screen.
#  - MIRO_JWT_EXP is the token lifetime (e.g. 1h, 30m, 900). Default 1h.
MIRO_JWT_KEY=
MIRO_JWT_EXP=1h
MIRO_MEETING_USERNAME=
MIRO_MEETING_PASSWORD=
MIRO_MEETING_PRESENTER=true

# MiroTalk reverse proxy (Caddy `meet` block). MEET_HOST is the EXACT public
# hostname you browse to for meetings — it is NOT auto-derived from DOMAIN, so
# set it explicitly (e.g. meet.lwtc.org.nz) and point its DNS A record at this VM.
# MIROTALK_UPSTREAM is where Caddy reaches MiroTalk: host.docker.internal:3010
# for a MiroTalk started with its own `docker run` (default), or a compose
# service name like mirotalk:3010. Must match MIROTALK_URL's host above.
MEET_HOST=                            # e.g. meet.lwtc.org.nz
MIROTALK_UPSTREAM=host.docker.internal:3010

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=                          # Sentry organization slug (for source map uploads)
SENTRY_PROJECT=                      # Sentry project slug (for source map uploads)
SENTRY_AUTH_TOKEN=                   # Sentry auth token (for source map uploads during build)

# Logging
LOG_LEVEL=info                       # debug, info, warn, error, fatal

# Cron
CRON_SECRET=your-cron-secret-here

# Legacy finance dashboard bridge
LEGACY_DASHBOARD_EXPORT_TOKEN=       # Optional shared bearer token; leave empty to disable the legacy export bridge

# Database Backups
# Backups are configured IN-APP (Admin -> Integrations -> Database Backups,
# /admin/backups) and stored encrypted (#2095). The enabled switch, S3
# bucket/region, access key/secret, retention, and restore-validation URL are NO
# LONGER read from the environment — do not set BACKUP_ENABLED / BACKUP_S3_* /
# BACKUP_RETENTION_DAYS / BACKUP_RESTORE_VALIDATION_URL here (they trigger a
# "no longer used" warning on the Backups page). Only the nightly schedule stays
# in the environment:
BACKUP_CRON_SCHEDULE=0 3 * * *       # Cron schedule for the nightly backup (default: daily 3 AM)

# Audit retention archive (optional separate PostgreSQL database)
AUDIT_ARCHIVE_DATABASE_URL=          # Preferred archive DB URL for AuditLogArchive rows
AUDIT_LOG_ARCHIVE_DATABASE_URL=      # Backward-compatible alias; leave empty when preferred var is set

# Bootstrap provisioning (optional, DR / clone — ADR-003)
CONFIG_BUNDLE_IMPORT_PATH=           # Path to a config-transfer bundle auto-imported on boot ONLY when the DB is empty of non-seed configuration; leave empty to disable
