# Copy to .env.staging for a non-production accessibility/staging target.
# Do not put live Stripe, Xero, SES, or production database credentials here.
# For a hosted staging target, keep STAGING_APP_URL, NEXTAUTH_URL, and the
# Xero redirect URIs on the same non-production origin.

# Staging target
STAGING_HTTP_PORT=3001
STAGING_POSTGRES_PORT=5433
DOMAIN=localhost
STAGING_APP_URL=http://localhost:3001
STAGING_CADDY_SITE=http://localhost
NEXTAUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true

# Database inside the staging Compose project
DB_PASSWORD=staging-password-change-me
DATABASE_URL=postgresql://tac:staging-password-change-me@localhost:5433/tacbookings

# Auth/session secrets. Generate real values before running shared staging:
#   openssl rand -base64 48
# Strong (64-hex) so the in-app credential-capture strength gate (#2079) passes
# and the Xero setup wizard E2E (#2080) can store credentials. Test-only value.
AUTH_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
NEXTAUTH_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional modules are turned on or off entirely from the admin Modules page
# (Admin > Setup > Modules). There are no module feature-flag env vars.
NEXT_PUBLIC_GA_MEASUREMENT_ID=         # Optional GA4 measurement id. Analytics still requires Admin > Modules opt-in plus visitor consent.

# Seed admin for non-production staging. Replace before running prisma/seed.ts.
SEED_ADMIN_EMAIL=staging-admin@example.org
SEED_ADMIN_PASSWORD=staging-seed-password-change-me
SEED_LODGE_PASSWORD=staging-lodge-password-change-me
# Stamp the club theme completed at seed so the public site renders its real
# header/footer/title chrome; the club-identity smoke E2E needs that chrome.
SEED_TOKOROA_THEME_COMPLETE=1

# Stripe test-mode placeholders only. DB-only cutover (#2082): the app no longer
# reads these — they are the SEED SOURCE the E2E stack writes into the encrypted
# store (e2e/setup/seed-stripe-credentials.ts). Leaving the placeholders makes the
# payment specs skip; drop real sk_test_/pk_test_ keys here to run them. Live keys
# are refused. The webhook secret is optional (only needed for webhook specs).
STRIPE_SECRET_KEY=sk_test_staging_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_staging_placeholder
STRIPE_WEBHOOK_SECRET=stripe_webhook_secret_staging_placeholder

# Xero CREDENTIALS (client id/secret, webhook key, token-encryption key and the
# redirect URI) are captured IN-APP and stored encrypted in the database (Admin >
# Integrations) — #2079. There are no XERO_CLIENT_ID / XERO_CLIENT_SECRET /
# XERO_REDIRECT_URI / XERO_ENCRYPTION_KEY / XERO_WEBHOOK_KEY env vars any more; if
# any are still set they are IGNORED and flagged in setup readiness for removal.
# The redirect URI derives from NEXTAUTH_URL. Only the operational tuning flags
# below remain (they are not credentials):
XERO_ENABLE_DAILY_MEMBERSHIP_REFRESH=false
XERO_ENABLE_LIVE_MEMBER_GROUP_LOOKUPS=false
XERO_ENABLE_AUTOLOAD_XERO_CONTACT_GROUPS=false
# TEST-ONLY (#2080): activates the mock-Xero E2E harness so the Xero setup wizard
# happy-path spec can run without touching real Xero. API_ORIGIN is the
# BROWSER-reachable origin (the staging stack maps host :3001 -> container
# :3000, and the operator's browser follows the consent URL there);
# INTERNAL_ORIGIN is the app's container-internal self-origin for server-side
# token/organisation calls (defaults to API_ORIGIN when unset). NEVER set
# either in a real deployment — leave them unset there.
XERO_MOCK_API_ORIGIN=http://localhost:3001
XERO_MOCK_INTERNAL_ORIGIN=http://127.0.0.1:3000
# The finance dashboard reads Xero reports through this same operational connection.

# Email is delivered to the local mailpit SMTP capture container defined in
# docker-compose.staging.yml — never to a live provider. This lets the
# email-code two-factor E2E spec (e2e/two-factor-email.spec.ts) read the emailed
# code back over mailpit's HTTP API. All four SMTP_RELAY vars must be present or
# email delivery resolves as "invalid" and every send throws; USE_AWS_SES must
# be false so exactly one provider flag is set. MAILPIT_HTTP_PORT is the host
# port the mailpit HTTP API is published on for the Playwright process.
USE_AWS_SES=false
USE_SMTP_RELAY=true
EMAIL_SERVER_HOST=mailpit
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=e2e
EMAIL_SERVER_PASSWORD=e2e
MAILPIT_HTTP_PORT=8025
SMTP_HOST=
SMTP_PORT=587
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
SES_SNS_TOPIC_ARN=
SES_SNS_ALLOW_UNSAFE_MISSING_TOPIC_ARN=false
EMAIL_FROM=staging@example.org

# Addy address autocomplete (server-side proxy)
ADDY_API_KEY=
ADDY_API_SECRET=

# Cron and backups stay disabled in this target
CRON_SECRET=staging-cron-secret-change-me
CRON_ENABLED=false
BACKUP_ENABLED=false
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=ap-southeast-2
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_RETENTION_DAYS=7
BACKUP_CRON_SCHEDULE=0 3 * * *
BACKUP_RESTORE_VALIDATION_URL=
AUDIT_ARCHIVE_DATABASE_URL=
AUDIT_LOG_ARCHIVE_DATABASE_URL=

# Optional observability for shared staging
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
LOG_LEVEL=info

# Legacy finance dashboard bridge stays off in staging
LEGACY_DASHBOARD_EXPORT_TOKEN=

# Accessibility verification defaults
STAGING_A11Y_PATHS=/,/login,/register,/forgot-password,/faq,/contact
STAGING_A11Y_OUT_DIR=reports/lighthouse/staging
