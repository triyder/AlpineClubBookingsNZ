{$DOMAIN} {
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		# Disabled: the legacy XSS auditor is removed from modern browsers and
		# enabling it could introduce information leaks in older ones. CSP is the control.
		X-XSS-Protection "0"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		# CSP is emitted by Next middleware so script nonces are generated per request.
		# style-src intentionally keeps 'unsafe-inline' there while Tailwind/Radix runtime styles are audited.
		# Defensive baseline: only applied if Next omits the header (e.g. middleware regression).
		# Caddy's `?` prefix means "set if not already present" so it never intersects with Next's policy.
		?Content-Security-Policy "default-src 'self'"
	}
	# Rewrite legacy /images/* requests to the runtime-serving API route so
	# uploaded images are served correctly without restarting containers.
	handle /images/* {
		uri strip_prefix /images
		rewrite * /api/images/uploaded{path}
		import /etc/caddy/deploy/tacbookings-active.caddy
	}
	handle /finance-legacy* {
		forward_auth app:3000 {
			uri /api/finance/legacy-dashboard/auth
		}
		reverse_proxy 172.26.3.200:8501
	}
	import /etc/caddy/deploy/tacbookings-active.caddy
}

# Canonicalize the www host onto the apex so a session established on one origin
# is never orphaned on the other (the session cookie is host-only). Mirrors the
# bookings./dashboard. redirects below; preserves the full path + query via {uri}.
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}

bookings.{$DOMAIN} {
	@root path /
	redir @root https://{$DOMAIN}/dashboard permanent
	redir * https://{$DOMAIN}{uri} permanent
}

dashboard.{$DOMAIN} {
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		# Disabled: the legacy XSS auditor is removed from modern browsers and
		# enabling it could introduce information leaks in older ones. CSP is the control.
		X-XSS-Protection "0"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
	}
	redir * https://{$DOMAIN}/finance-legacy{uri} permanent
}
