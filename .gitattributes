# Prisma migrations are generated, immutable, and checksummed by Prisma.
# Their bytes must stay identical across the public repo and downstream forks,
# so git must not flag (or try to auto-fix) whitespace in them — e.g. a
# trailing blank line at EOF would otherwise trip `git diff --check` on merge.
prisma/migrations/**/*.sql -whitespace

# ESM scripts are imported by vitest tests as well as run via `node`. A CRLF
# checkout (Windows autocrlf) of a shebang line breaks vite-node's import of
# the module, so these always materialise with LF.
scripts/*.mjs text eol=lf

# The schema is hand-edited (AGENTS.md "Change Discipline") and is the file most
# likely to be ported between the public repo and its forks. A Windows editor
# silently rewriting it to CRLF turns a 14-line change into a ~9,400-line diff
# that conflicts on every line at the next port (#2129), so pin it to LF.
prisma/schema.prisma text eol=lf
