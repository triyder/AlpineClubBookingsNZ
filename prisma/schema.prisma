// ---------------------------------------------------------------------------
// Account Credits
// ---------------------------------------------------------------------------

model MemberCredit {
  id                          String     @id @default(cuid())
  memberId                    String
  amountCents                 Int // Positive = credit added, negative = credit used
  type                        CreditType
  description                 String // Human-readable reason
  requestedById               String? // Admin who requested a manual adjustment
  approvedById                String? // Admin who approved a manual adjustment
  approvalRequestId           String?    @unique // Links approved manual adjustments to their request
  sourceBookingId             String? // Booking that generated the credit (cancellation)
  // #1636: restore-per-source-booking dedupe key. Set ONLY by
  // restoreCreditFromBooking (alongside sourceBookingId), so a second restore of
  // the same booking's applied credit is structurally impossible independent of
  // the caller's advisory-lock granularity. A dedicated column — NOT the shared
  // sourceBookingId — because sourceBookingId + type=CANCELLATION_REFUND is
  // written by THREE legitimate paths for one booking (restoreCreditFromBooking,
  // createCancellationCredit's held-as-credit refund, and the Xero inbound
  // invoice-paid-effects late-cash credit), so a unique over (sourceBookingId,
  // type) would reject those co-occurring rows. Nullable + @unique => Postgres
  // permits many NULLs (every non-restore row) but at most one non-null per
  // booking. Bare scalar, not a FK: sourceBookingId's FK already carries
  // referential integrity to the same booking.
  restoredFromBookingId       String?    @unique
  sourceBookingModificationId String?    @unique // Booking modification that generated the credit
  appliedToBookingId          String? // Booking where credit was spent
  xeroCreditNoteId            String? // Linked Xero credit note ID
  createdAt                   DateTime   @default(now())

  member                    Member                        @relation(fields: [memberId], references: [id], onDelete: Restrict)
  requestedBy               Member?                       @relation("RequestedAdminCredits", fields: [requestedById], references: [id], onDelete: SetNull)
  approvedBy                Member?                       @relation("ApprovedAdminCredits", fields: [approvedById], references: [id], onDelete: SetNull)
  approvalRequest           AdminCreditAdjustmentRequest? @relation("ApprovedAdminCreditAdjustment", fields: [approvalRequestId], references: [id], onDelete: SetNull)
  sourceBooking             Booking?                      @relation("CreditSource", fields: [sourceBookingId], references: [id], onDelete: SetNull)
  sourceBookingModification BookingModification?          @relation("CreditSourceModification", fields: [sourceBookingModificationId], references: [id], onDelete: SetNull)
  appliedToBooking          Booking?                      @relation("CreditApplied", fields: [appliedToBookingId], references: [id], onDelete: SetNull)
  // #1620: slices of THIS credit lot (a positive funding row) that have been
  // allocated to booking invoices as Xero credit notes. Empty for negative
  // BOOKING_APPLIED rows and for lots never used to reduce an IB invoice.
  noteAllocations           MemberCreditNoteAllocation[]  @relation("CreditLotAllocations")

  @@index([memberId])
  @@index([requestedById])
  @@index([approvedById])
  @@index([sourceBookingId])
  @@index([appliedToBookingId])
}

/// #1620 — per-note credit-lot allocation ledger for "allocate-existing" applied
/// credit. When a member applies account credit to an Internet-Banking booking,
/// the raise-path allocation engine reduces the FULL Xero invoice by allocating
/// the member's existing floating ACCRECCREDIT notes (or a freshly minted note
/// for an admin-adjustment remainder that has no Xero note). Each row records one
/// mutable working slice of one funding lot consumed against one booking's
/// invoice. A funding
/// note's remaining unallocated balance = MemberCredit.amountCents (the positive
/// lot) minus the sum of amountCents over its allocation rows. Idempotency anchor
/// for the per-note Xero allocation outbox op (localModel
/// "MemberCreditNoteAllocation", localId = this row's id).
model MemberCreditNoteAllocation {
  id                 String   @id @default(cuid())
  // The positive funding MemberCredit lot this slice draws from.
  memberCreditId     String
  // The Xero credit note carrying the slice: the lot's existing floating note,
  // or a freshly minted note for an admin-adjustment (noteless) lot.
  xeroCreditNoteId   String
  // The booking whose Xero invoice the note is allocated against. Deliberately a
  // bare scalar with no FK to Booking (mirrors MemberCredit.restoredFromBookingId):
  // working slices can be reduced/deleted after provider-verified deallocation,
  // but remain bare scalars so booking hard-delete neither cascades nor blocks.
  // Durable equivalent audit survives in the XeroSyncOperation requestPayload
  // checkpoint/history and inactive/active XeroObjectLink provenance history.
  appliedToBookingId String
  // Positive cents drawn from the lot for this booking (never exceeds the lot's
  // remaining balance).
  amountCents        Int
  createdAt          DateTime @default(now())

  memberCredit MemberCredit @relation("CreditLotAllocations", fields: [memberCreditId], references: [id], onDelete: Restrict)

  // One slice per (lot, booking): the allocation engine re-runs idempotently and
  // upserts on this key. Explicit map: the default name would exceed Postgres's
  // 63-char identifier limit.
  @@unique([memberCreditId, appliedToBookingId], map: "MemberCreditNoteAllocation_lot_booking_key")
  @@index([appliedToBookingId])
  @@index([xeroCreditNoteId])
}

model AdminCreditAdjustmentRequest {
  id             String                             @id @default(cuid())
  memberId       String
  amountCents    Int
  description    String
  idempotencyKey String
