// TACBookings - Tokoroa Alpine Club Booking System
// Single source of truth for all database models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  MEMBER
  ADMIN
  LODGE
}

enum AgeTier {
  INFANT
  CHILD
  YOUTH
  ADULT
}

enum ApplicationStatus {
  PENDING_NOMINATORS
  PENDING_ADMIN
  APPROVED
  REJECTED
}

enum SubscriptionStatus {
  NOT_INVOICED
  UNPAID
  PAID
  OVERDUE
}

enum SeasonType {
  WINTER
  SUMMER
}

enum BookingStatus {
  DRAFT
  PENDING
  CONFIRMED
  PAID
  BUMPED
  CANCELLED
  COMPLETED
  WAITLISTED
  WAITLIST_OFFERED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PromoCodeType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_NIGHTS
}

enum ChoreStatus {
  SUGGESTED
  CONFIRMED
  COMPLETED
}

enum CreditType {
  CANCELLATION_REFUND
  ADMIN_ADJUSTMENT
  BOOKING_APPLIED
}

enum AgeRestriction {
  ANY
  ADULTS_ONLY
  MIXED_PREFERRED
  ADULT_SUPERVISED
}

enum ChoreTimeOfDay {
  MORNING
  EVENING
  ANYTIME
}

enum ChoreFrequencyMode {
  DAILY
  EVERY_X_DAYS
  SPECIFIC_DAYS
}

// ---------------------------------------------------------------------------
// Member & Auth
// ---------------------------------------------------------------------------

model Member {
  id                  String    @id @default(cuid())
  // Lookup index only in Prisma schema. Login identity uniqueness is enforced
  // by the manual partial unique index Member_email_login_unique
  // (WHERE canLogin = true), because Prisma schema cannot express partial unique indexes.
  email               String
  passwordHash        String
  forcePasswordChange Boolean   @default(false)
  passwordChangedAt   DateTime?
  // Email verification: new registrations start as false.
  // Existing members should be bulk-updated: UPDATE "Member" SET "emailVerified" = true;
  emailVerified       Boolean   @default(false)
  firstName           String
  lastName            String
  dateOfBirth         DateTime?

  // Structured phone (matches Xero's countryCode/areaCode/number format)
  phoneCountryCode String? // e.g. "64"
  phoneAreaCode    String? // e.g. "27"
  phoneNumber      String? // e.g. "4224115"

  // Physical address (Xero STREET type)
  streetAddressLine1 String?
  streetAddressLine2 String?
  streetCity         String?
  streetRegion       String?
  streetPostalCode   String?
  streetCountry      String?

  // Postal address (Xero POBOX type)
  postalAddressLine1 String?
  postalAddressLine2 String?
  postalCity         String?
  postalRegion       String?
  postalPostalCode   String?
  postalCountry      String?

  role          Role      @default(MEMBER)
  ageTier       AgeTier   @default(ADULT)
  xeroContactId String?   @unique
  active        Boolean   @default(true)
  canLogin      Boolean   @default(false) // true for members allowed to authenticate; the DB enforces one canLogin member per email
  joinedDate    DateTime? // Membership start date, sourced from Xero first invoice
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Family/dependent support: dependents can share parent's email or have their own
  parentMemberId     String?
  inheritParentEmail Boolean  @default(true) // When true, dependent uses parent's email
  parent             Member?  @relation("FamilyMembers", fields: [parentMemberId], references: [id], onDelete: SetNull)
  dependents         Member[] @relation("FamilyMembers")

  // Secondary parent for split families (e.g. child with separated parents)
  secondaryParentId   String?
  secondaryParent     Member?  @relation("SecondaryFamily", fields: [secondaryParentId], references: [id], onDelete: SetNull)
  secondaryDependents Member[] @relation("SecondaryFamily")

  // Flexible email inheritance: use any adult's email for communications.
  // Takes precedence over the inheritParentEmail + parentMemberId mechanism.
  inheritEmailFromId  String?
  inheritEmailFrom    Member?  @relation("EmailInheritance", fields: [inheritEmailFromId], references: [id], onDelete: SetNull)
  emailInheritanceFor Member[] @relation("EmailInheritance")

  // Family group: links primary adult members (e.g. spouses) for shared booking quick-add
  // @deprecated — use FamilyGroupMember join table instead
  familyGroupId String?
  familyGroup   FamilyGroup? @relation("FamilyGroupLegacy", fields: [familyGroupId], references: [id])

  // Many-to-many family group memberships via join table
  familyGroupMemberships FamilyGroupMember[]

  // Relations
  passwordResetTokens       PasswordResetToken[]
  emailVerificationTokens   EmailVerificationToken[]
  emailChangeTokens         EmailChangeToken[]
  subscriptions             MemberSubscription[]
  bookings                  Booking[]
  guestAppearances          BookingGuest[]
  promoRedemptions          PromoRedemption[]
  promoCodeAssignments      PromoCodeAssignment[]
  notificationPreference    NotificationPreference?
  hutLeaderAssignments      HutLeaderAssignment[]
  familyGroupRequests       FamilyGroupJoinRequest[] @relation("FamilyGroupRequester")
  familyGroupInvitations    FamilyGroupJoinRequest[] @relation("FamilyGroupInvitedMember")
  familyGroupLinkedRequests FamilyGroupJoinRequest[] @relation("FamilyGroupLinkedMember")
  deletionRequests          DeletionRequest[]
  credits                   MemberCredit[]
  bookingsCreatedOnBehalf   Booking[]                @relation("BookingsCreatedBy")
  refundRequests            RefundRequest[]

  @@index([email])
  @@index([xeroContactId])
  @@index([parentMemberId])
  @@index([secondaryParentId])
  @@index([familyGroupId])
  @@index([inheritEmailFromId])
  @@index([canLogin])
  @@index([active])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  memberId  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  memberId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([memberId])
}

model EmailChangeToken {
  id        String   @id @default(cuid())
  memberId  String
  newEmail  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([memberId])
}

model MemberApplication {
  id                    String            @id @default(cuid())
  applicantFirstName    String
  applicantLastName     String
  applicantEmail        String
  applicantDateOfBirth  DateTime?
  applicantPhone        String?
  applicantAddress      Json?
  familyMembers         Json?
  nominator1Email       String
  nominator2Email       String
  nominator1Id          String?
  nominator2Id          String?
  nominator1ConfirmedAt DateTime?
  nominator2ConfirmedAt DateTime?
  status                ApplicationStatus @default(PENDING_NOMINATORS)
  adminNotes            String?
  reviewedBy            String?
  reviewedAt            DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  nominationTokens NominationToken[]

  // Pending-application uniqueness is enforced by the manual partial unique index
  // MemberApplication_pending_applicantEmail_unique in Prisma migrations.
  @@index([applicantEmail])
  @@index([status, createdAt])
  @@index([nominator1Id])
  @@index([nominator2Id])
}

model NominationToken {
  id                String    @id @default(cuid())
  token             String    @unique
  applicationId     String
  nominatorMemberId String
  expiresAt         DateTime
  confirmedAt       DateTime?
  createdAt         DateTime  @default(now())

  application MemberApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([nominatorMemberId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Membership Subscriptions
// ---------------------------------------------------------------------------

model MemberSubscription {
  id                   String             @id @default(cuid())
  memberId             String
  seasonYear           Int
  status               SubscriptionStatus @default(NOT_INVOICED)
  xeroInvoiceId        String?
  xeroInvoiceNumber    String?
  xeroOnlineInvoiceUrl String?
  paidAt               DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Relations
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, seasonYear])
  @@index([memberId])
  @@index([seasonYear])
  @@index([seasonYear, status])
}

// ---------------------------------------------------------------------------
// Seasons & Rates
// ---------------------------------------------------------------------------

model Season {
  id        String     @id @default(cuid())
  name      String
  type      SeasonType
  startDate DateTime   @db.Date
  endDate   DateTime   @db.Date
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  rates SeasonRate[]

  @@index([startDate, endDate])
}

model SeasonRate {
  id                 String  @id @default(cuid())
  seasonId           String
  ageTier            AgeTier
  isMember           Boolean
  pricePerNightCents Int

  // Relations
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, ageTier, isMember])
  @@index([seasonId])
}

// ---------------------------------------------------------------------------
// Bookings
// ---------------------------------------------------------------------------

model Booking {
  id                     String        @id @default(cuid())
  memberId               String
  checkIn                DateTime      @db.Date
  checkOut               DateTime      @db.Date
  status                 BookingStatus @default(PENDING)
  totalPriceCents        Int
  discountCents          Int           @default(0)
  finalPriceCents        Int
  hasNonMembers          Boolean       @default(false)
  nonMemberHoldUntil     DateTime?
  draftExpiresAt         DateTime?
  notes                  String?       @db.VarChar(500)
  expectedArrivalTime    String?       @db.VarChar(5)
  createdById            String? // Admin who created this booking on behalf of the member
  waitlistPosition       Int?
  waitlistOfferedAt      DateTime?
  waitlistOfferExpiresAt DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  // Relations
  member                  Member                @relation(fields: [memberId], references: [id], onDelete: Restrict)
  createdBy               Member?               @relation("BookingsCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  guests                  BookingGuest[]
  payment                 Payment?
  choreAssignments        ChoreAssignment[]
  promoRedemption         PromoRedemption?
  modifications           BookingModification[]
  creditsFromCancellation MemberCredit[]        @relation("CreditSource")
  creditsApplied          MemberCredit[]        @relation("CreditApplied")
  refundRequests          RefundRequest[]

  @@index([memberId])
  @@index([checkIn, checkOut])
  @@index([status])
  @@index([memberId, status])
  @@index([memberId, status, checkIn])
  @@index([status, createdAt])
  @@index([status, checkIn, checkOut, createdAt])
}

model BookingGuest {
  id         String    @id @default(cuid())
  bookingId  String
  firstName  String
  lastName   String
  ageTier    AgeTier
  isMember   Boolean   @default(false)
  memberId   String?
  priceCents Int
  arrivedAt  DateTime?
  departedAt DateTime?
  createdAt  DateTime  @default(now())

  // Relations
  booking          Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  member           Member?           @relation(fields: [memberId], references: [id], onDelete: SetNull)
  choreAssignments ChoreAssignment[]
  choreTokens      GuestChoreToken[]

  @@index([bookingId])
  @@index([memberId])
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------

model Payment {
  id                        String        @id @default(cuid())
  bookingId                 String        @unique
  amountCents               Int
  stripePaymentIntentId     String?       @unique
  stripePaymentMethodId     String?
  stripeSetupIntentId       String?       @unique
  stripeCustomerId          String?
  xeroInvoiceId             String?       @unique
  xeroInvoiceNumber         String?
  status                    PaymentStatus @default(PENDING)
  refundedAmountCents       Int           @default(0)
  changeFeeCents            Int           @default(0)
  additionalPaymentIntentId String?       @unique
  additionalAmountCents     Int           @default(0)
  additionalPaymentStatus   String? // PENDING, SUCCEEDED, FAILED
  xeroRefundCreditNoteId    String? // Track Xero credit note to prevent duplicates
  creditAppliedCents        Int           @default(0) // Account credit applied to this booking
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([stripePaymentIntentId])
  @@index([additionalPaymentIntentId])
  @@index([status, createdAt])
}

// ---------------------------------------------------------------------------
// Promo Codes
// ---------------------------------------------------------------------------

model PromoCode {
  id                 String        @id @default(cuid())
  code               String        @unique
  description        String?
  type               PromoCodeType
  valueCents         Int?
  percentOff         Int?
  freeNights         Int?
  maxRedemptions     Int?
  currentRedemptions Int           @default(0)
  validFrom          DateTime?
  validUntil         DateTime?
  bookingStartFrom   DateTime? // Gate by booking CHECK-IN date (separate from validFrom/validUntil)
  bookingStartUntil  DateTime? // Gate by booking CHECK-IN date (separate from validFrom/validUntil)
  membersOnly        Boolean       @default(false)
  singleUse          Boolean       @default(false)
  active             Boolean       @default(true)
  archivedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  redemptions PromoRedemption[]
  assignments PromoCodeAssignment[]

  @@index([code])
  @@index([active])
  @@index([archivedAt])
}

model PromoRedemption {
  id            String   @id @default(cuid())
  promoCodeId   String
  bookingId     String   @unique
  memberId      String
  discountCents Int
  createdAt     DateTime @default(now())

  // Relations
  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)
  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([promoCodeId])
  @@index([memberId])
}

model PromoCodeAssignment {
  id          String   @id @default(cuid())
  promoCodeId String
  memberId    String
  createdAt   DateTime @default(now())

  // Relations
  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, memberId])
  @@index([promoCodeId])
  @@index([memberId])
}

// ---------------------------------------------------------------------------
// Chore Roster
// ---------------------------------------------------------------------------

model ChoreTemplate {
  id                   String             @id @default(cuid())
  name                 String
  description          String?
  recommendedPeopleMin Int                @default(1)
  recommendedPeopleMax Int                @default(2)
  isEssential          Boolean            @default(false)
  ageRestriction       AgeRestriction     @default(ANY)
  conditionalNote      String?
  minAge               Int                @default(0)
  sortOrder            Int                @default(0)
  timeOfDay            ChoreTimeOfDay     @default(ANYTIME)
  frequencyMode        ChoreFrequencyMode @default(DAILY)
  frequencyDays        Int?
  frequencyDaysOfWeek  Int[]
  active               Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Relations
  assignments ChoreAssignment[]
}

model ChoreAssignment {
  id              String      @id @default(cuid())
  choreTemplateId String
  bookingId       String
  bookingGuestId  String?
  date            DateTime    @db.Date
  status          ChoreStatus @default(SUGGESTED)
  completedAt     DateTime?
  completedVia    String? // "KIOSK", "ADMIN", or "GUEST_LINK"
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  choreTemplate ChoreTemplate @relation(fields: [choreTemplateId], references: [id], onDelete: Restrict)
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingGuest  BookingGuest? @relation(fields: [bookingGuestId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([bookingId])
  @@index([bookingGuestId])
  @@index([choreTemplateId])
}

// ---------------------------------------------------------------------------
// Cancellation Policy
// ---------------------------------------------------------------------------

model CancellationPolicy {
  id                     String   @id @default(cuid())
  daysBeforeStay         Int
  refundPercentage       Int // Card refund percentage
  creditRefundPercentage Int? // Credit refund percentage (null = same as refundPercentage)
  fixedFeeCents          Int      @default(0) // Fixed fee deducted from card refunds per tier
  creditFixedFeeCents    Int? // Fixed fee deducted from credit refunds per tier (null = same as fixedFeeCents)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([daysBeforeStay])
}

// ---------------------------------------------------------------------------
// Booking Periods (date-specific policy overrides, e.g. school holidays)
// ---------------------------------------------------------------------------

model BookingPeriod {
  id                String   @id @default(cuid())
  name              String // e.g. "School Holidays Jul 2026"
  startDate         DateTime @db.Date
  endDate           DateTime @db.Date
  nonMemberHoldDays Int      @default(7)
  cancellationRules Json // Array of {daysBeforeStay: number, refundPercentage: number}
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([startDate, endDate])
}

// ---------------------------------------------------------------------------
// Booking Defaults (global settings, single row)
// ---------------------------------------------------------------------------

model BookingDefaults {
  id                String @id @default("default")
  nonMemberHoldDays Int    @default(7)
}

// ---------------------------------------------------------------------------
// Minimum Stay Policies
// ---------------------------------------------------------------------------

model MinimumStayPolicy {
  id            String   @id @default(cuid())
  name          String // e.g. "Winter Saturday Minimum Stay"
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  triggerDays   Int[] // Days of week: 0=Sunday, 1=Monday, ..., 6=Saturday
  minimumNights Int
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([startDate, endDate])
  @@index([active])
}

// ---------------------------------------------------------------------------
// Xero OAuth Token (single row)
// ---------------------------------------------------------------------------

model XeroToken {
  id           String   @id @default(cuid())
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  tenantId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Webhook Idempotency (prevents duplicate event processing)
// ---------------------------------------------------------------------------

model ProcessedWebhookEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  source      String // "stripe" or "xero"
  eventType   String
  processedAt DateTime @default(now())

  @@index([source])
}

// ---------------------------------------------------------------------------
// Webhook Delivery Monitoring (OBS-08)
// ---------------------------------------------------------------------------

model WebhookLog {
  id         String   @id @default(cuid())
  source     String // "stripe" or "xero"
  eventType  String
  eventId    String
  status     String // "success" or "failure"
  durationMs Int
  error      String?
  createdAt  DateTime @default(now())

  @@index([source])
  @@index([createdAt])
  @@index([source, createdAt])
}

// ---------------------------------------------------------------------------
// Audit Log (tracks sensitive admin and system actions)
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  memberId  String?
  targetId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([memberId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Booking Modifications (history of changes to bookings)
// ---------------------------------------------------------------------------

model BookingModification {
  id               String   @id @default(cuid())
  bookingId        String
  memberId         String
  modificationType String // DATE_CHANGE | GUEST_ADD | GUEST_REMOVE | EXTEND_STAY
  previousData     Json // snapshot of changed fields before
  newData          Json // snapshot of changed fields after
  priceDiffCents   Int      @default(0) // positive = owes more, negative = refund
  changeFeeCents   Int      @default(0) // late-notice fee charged
  createdAt        DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([memberId])
}

// ---------------------------------------------------------------------------
// Email Delivery Tracking (N-10)
// ---------------------------------------------------------------------------

enum EmailLogStatus {
  QUEUED
  SENT
  FAILED
  BOUNCED
}

model EmailLog {
  id            String         @id @default(cuid())
  to            String
  subject       String
  templateName  String
  htmlBody      String? // Stored only for retry-safe templates; token-bearing templates are redacted
  status        EmailLogStatus @default(QUEUED)
  errorMessage  String?
  attempts      Int            @default(1)
  lastAttemptAt DateTime       @default(now())
  sentAt        DateTime?
  messageId     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([to])
  @@index([status])
  @@index([createdAt])
  @@index([status, attempts])
  @@index([templateName, status, createdAt])
}

// ---------------------------------------------------------------------------
// Notification Preferences (N-08)
// ---------------------------------------------------------------------------

model NotificationPreference {
  id                      String   @id @default(cuid())
  memberId                String   @unique
  bookingConfirmation     Boolean  @default(true)
  bookingReminder         Boolean  @default(true)
  bookingBumped           Boolean  @default(true)
  bookingCancelled        Boolean  @default(true)
  bookingWaitlist         Boolean  @default(true)
  choreRoster             Boolean  @default(true)
  marketingEmails         Boolean  @default(false)
  adminNewBooking         Boolean  @default(true)
  adminPaymentFailure     Boolean  @default(true)
  adminPendingDeadline    Boolean  @default(true)
  adminBookingBumped      Boolean  @default(true)
  adminXeroSyncError      Boolean  @default(true)
  adminCapacityWarning    Boolean  @default(true)
  adminDailyDigest        Boolean  @default(true)
  adminWaitlistOffer      Boolean  @default(true)
  adminFamilyGroupRequest Boolean  @default(true)
  adminRefundRequest      Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Cron Job Run Tracking (OBS-09)
// ---------------------------------------------------------------------------

model CronJobRun {
  id            String    @id @default(cuid())
  jobName       String
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  durationMs    Int?
  status        String // SUCCESS | FAILURE | SKIPPED
  resultSummary Json?
  error         String?
  createdAt     DateTime  @default(now())

  @@index([jobName])
  @@index([startedAt])
}

// ---------------------------------------------------------------------------
// Hut Leader Assignment (F8)
// ---------------------------------------------------------------------------

model HutLeaderAssignment {
  id           String   @id @default(cuid())
  memberId     String
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  hutLeaderPin String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([startDate, endDate])
}

// ---------------------------------------------------------------------------
// Guest Chore Token (F10)
// ---------------------------------------------------------------------------

model GuestChoreToken {
  id             String   @id @default(cuid())
  token          String   @unique
  bookingGuestId String
  date           DateTime @db.Date
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  bookingGuest BookingGuest @relation(fields: [bookingGuestId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([bookingGuestId])
}

// ---------------------------------------------------------------------------
// Family Groups (links primary adult members for shared booking quick-add)
// ---------------------------------------------------------------------------

model FamilyGroup {
  id            String                   @id @default(cuid())
  name          String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  // @deprecated — legacy single-group FK; use memberships (FamilyGroupMember) instead
  legacyMembers Member[]                 @relation("FamilyGroupLegacy")
  memberships   FamilyGroupMember[]
  joinRequests  FamilyGroupJoinRequest[]
}

model FamilyGroupMember {
  id            String   @id @default(cuid())
  familyGroupId String
  memberId      String
  role          String   @default("MEMBER") // ADMIN or MEMBER (group admin can manage the group)
  joinedAt      DateTime @default(now())

  familyGroup FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  member      Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([familyGroupId, memberId])
  @@index([memberId])
  @@index([familyGroupId])
}

model FamilyGroupJoinRequest {
  id            String    @id @default(cuid())
  familyGroupId String
  requesterId   String
  type          String    @default("JOIN_REQUEST") // JOIN_REQUEST | ADULT_INVITE | CHILD_REQUEST
  status        String    @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?

  // For ADULT_INVITE: the member being invited
  invitedMemberId String?
  invitedMember   Member? @relation("FamilyGroupInvitedMember", fields: [invitedMemberId], references: [id])

  // For CHILD_REQUEST: child details submitted by parent
  childFirstName   String?
  childLastName    String?
  childDateOfBirth DateTime?

  // Set by admin when approving CHILD_REQUEST — links to existing member
  linkedMemberId String?
  linkedMember   Member? @relation("FamilyGroupLinkedMember", fields: [linkedMemberId], references: [id])

  familyGroup FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  requester   Member      @relation("FamilyGroupRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([familyGroupId])
  @@index([requesterId])
  @@index([invitedMemberId])
  @@index([status])
  @@index([type])
}

// ---------------------------------------------------------------------------
// Xero Account Mappings (XAM-01)
// ---------------------------------------------------------------------------

model XeroAccountMapping {
  id        String   @id @default(cuid())
  key       String   @unique // hutFeesIncome | hutFeeRefunds | stripeBankAccount | stripeFees | subscriptionIncome | hutFeeItem | hutFeeRefundItem | entranceFeeItem | entranceFeeAmountCents
  code      String? // null = not configured, use application default (GL account code or amount string)
  itemCode  String? // Xero Item Code — when set, Xero auto-fills account from Item config
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ---------------------------------------------------------------------------
// Xero Item Code Mappings — granular per age tier / season / member status
// ---------------------------------------------------------------------------

enum EntranceFeeCategory {
  ADULT
  YOUTH
  CHILD
  FAMILY
}

model XeroItemCodeMapping {
  id                  String               @id @default(cuid())
  category            String               // "HUT_FEE" | "ENTRANCE_FEE"
  ageTier             AgeTier?             // HUT_FEE only
  seasonType          SeasonType?          // HUT_FEE only
  isMember            Boolean?             // HUT_FEE only
  entranceFeeCategory EntranceFeeCategory? // ENTRANCE_FEE only
  itemCode            String?              // Optional Xero Item Code
  amountCents         Int?                 // ENTRANCE_FEE only (per-category pricing)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([category, ageTier, seasonType, isMember])
  @@unique([category, entranceFeeCategory])
  @@index([category])
}

// ---------------------------------------------------------------------------
// Age Tier Settings (Issue 14 — configurable age group boundaries)
// ---------------------------------------------------------------------------

model AgeTierSetting {
  id        String   @id @default(cuid())
  tier      AgeTier  @unique
  minAge    Int
  maxAge    Int? // null for ADULT (no upper limit)
  label     String // e.g. "Child (under 10)"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

// ---------------------------------------------------------------------------
// Account Deletion Requests (F-COMP-04)
// ---------------------------------------------------------------------------

enum DeletionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model DeletionRequest {
  id         String                @id @default(cuid())
  memberId   String
  status     DeletionRequestStatus @default(PENDING)
  reason     String? // Optional free-text reason from member
  adminNote  String? // Note from admin on approve/reject
  reviewedBy String? // Admin member ID
  reviewedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Account Credits (Issue #37)
// ---------------------------------------------------------------------------

model MemberCredit {
  id                 String     @id @default(cuid())
  memberId           String
  amountCents        Int // Positive = credit added, negative = credit used
  type               CreditType
  description        String // Human-readable reason
  sourceBookingId    String? // Booking that generated the credit (cancellation)
  appliedToBookingId String? // Booking where credit was spent
  xeroCreditNoteId   String? // Linked Xero credit note ID
  createdAt          DateTime   @default(now())

  member           Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  sourceBooking    Booking? @relation("CreditSource", fields: [sourceBookingId], references: [id], onDelete: SetNull)
  appliedToBooking Booking? @relation("CreditApplied", fields: [appliedToBookingId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@index([sourceBookingId])
  @@index([appliedToBookingId])
}

// ---------------------------------------------------------------------------
// Group Discount Settings (P5.1)
// ---------------------------------------------------------------------------

model GroupDiscountSetting {
  id           String   @id @default("default")
  minGroupSize Int      @default(5)
  summerOnly   Boolean  @default(true)
  enabled      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Refund Requests / Appeals (P5.4)
// ---------------------------------------------------------------------------

enum RefundRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model RefundRequest {
  id                   String              @id @default(cuid())
  bookingId            String
  memberId             String
  reason               String
  requestedAmountCents Int?
  status               RefundRequestStatus @default(PENDING)
  adminNotes           String?
  approvedAmountCents  Int?
  reviewedBy           String?
  reviewedAt           DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([memberId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Committee Members (public-facing committee page, admin-managed)
// ---------------------------------------------------------------------------

model CommitteeMember {
  id          String   @id @default(cuid())
  role        String // Position title (e.g. "President")
  name        String // Display name
  phone       String // Contact phone number
  email       String? // Optional email address
  contactKey  String?  @unique // Maps to /contact?recipient=key
  description String // Role description
  sortOrder   Int      @default(0) // Display order on public page
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
