// ---------------------------------------------------------------------------
// Member & Auth
// ---------------------------------------------------------------------------

model Member {
  id                      String           @id @default(cuid())
  // Lookup index only in Prisma schema. Login identity uniqueness is enforced
  // by the manual partial unique index Member_email_login_unique
  // (WHERE canLogin = true), because Prisma schema cannot express partial unique indexes.
  email                   String
  passwordHash            String
  forcePasswordChange     Boolean          @default(false)
  passwordChangedAt       DateTime?
  lastLoginAt             DateTime?
  twoFactorEnabled        Boolean          @default(false)
  twoFactorMethod         TwoFactorMethod?
  totpSecret              String?
  twoFactorEnrolledAt     DateTime?
  twoFactorFailedAttempts Int              @default(0)
  twoFactorLockedUntil    DateTime?
  // Email verification: new registrations start as false.
  // Existing members should be bulk-updated: UPDATE "Member" SET "emailVerified" = true;
  emailVerified           Boolean          @default(false)
  title                   Title?
  firstName               String
  lastName                String
  gender                  Gender?
  dateOfBirth             DateTime?
  // Free-text occupation. Optional, adult-only, and admin-toggleable via
  // MemberFieldsSettings.showOccupation.
  occupation              String?

  // Structured phone (matches Xero's countryCode/areaCode/number format)
  phoneCountryCode String? // e.g. "64"
  phoneAreaCode    String? // e.g. "27"
  phoneNumber      String? // e.g. "4224115"
  // Per-member opt-in to show this member's phone number on lodge screens
  // (kiosk + lobby display), default OFF (#37/#124). Only ever surfaced when the
  // lodge also enables it (Lodge.showGuestPhonesOnScreens) AND the member is an
  // adult — enforced in the serving serialisers, never in templates.
  lodgeScreenPhoneOptIn Boolean @default(false)

  // Physical address (Xero STREET type)
  streetAddressLine1 String?
  streetAddressLine2 String?
  streetCity         String?
  streetRegion       String?
  streetPostalCode   String?
  streetCountry      String?

  // Postal address (Xero POBOX type)
  postalAddressLine1 String?
  postalAddressLine2 String?
  postalCity         String?
  postalRegion       String?
  postalPostalCode   String?
  postalCountry      String?

  role                                Role               @default(USER)
  financeAccessLevel                  FinanceAccessLevel @default(NONE)
  ageTier                             AgeTier            @default(ADULT)
  xeroContactId                       String?            @unique
  active                              Boolean            @default(true)
  canLogin                            Boolean            @default(false) // true for members allowed to authenticate; the DB enforces one canLogin member per email
  profileCompletedAt                  DateTime?
  detailsConfirmedAt                  DateTime?
  detailsConfirmedByMemberId          String?
  onboardingConfirmedAt               DateTime?
  joinedDate                          DateTime? // Membership start date, sourced from Xero first invoice
  // Historical life-membership date retained for existing records. Seasonal
  // membership type changes are managed through SeasonalMembershipAssignment.
  lifeMemberDate                      DateTime?
  requiresInduction                   Boolean            @default(false) // Admin-set flag: member must complete a lodge induction
  hutLeaderEligible                   Boolean            @default(false)
  hutLeaderEligibleAt                 DateTime?
  cancelledAt                         DateTime?
  cancelledReason                     String?
  cancelledViaRequestId               String?
  comments                            String?            @db.Text
  archivedAt                          DateTime?
  archivedReason                      String?
  archivedViaLifecycleActionRequestId String?
  createdAt                           DateTime           @default(now())
  updatedAt                           DateTime           @updatedAt

  // Family/dependent support: dependents can share parent's email or have their own
  parentMemberId     String?
  inheritParentEmail Boolean  @default(true) // When true, dependent uses parent's email
  parent             Member?  @relation("FamilyMembers", fields: [parentMemberId], references: [id], onDelete: SetNull)
  dependents         Member[] @relation("FamilyMembers")

  // Secondary parent for split families (e.g. child with separated parents)
  secondaryParentId   String?
  secondaryParent     Member?  @relation("SecondaryFamily", fields: [secondaryParentId], references: [id], onDelete: SetNull)
  secondaryDependents Member[] @relation("SecondaryFamily")

  // Flexible email inheritance: dependents can reuse a primary adult's email for communications.
  // The source must be an adult primary member who is not inheriting from someone else.
  // Takes precedence over the inheritParentEmail + parentMemberId mechanism.
  inheritEmailFromId  String?
  inheritEmailFrom    Member?  @relation("EmailInheritance", fields: [inheritEmailFromId], references: [id], onDelete: SetNull)
  emailInheritanceFor Member[] @relation("EmailInheritance")

  detailsConfirmedBy                Member?                        @relation("MemberDetailsConfirmedBy", fields: [detailsConfirmedByMemberId], references: [id], onDelete: SetNull)
  detailsConfirmedFor               Member[]                       @relation("MemberDetailsConfirmedBy")
  cancelledViaRequest               MembershipCancellationRequest? @relation("CancelledViaMembershipCancellationRequest", fields: [cancelledViaRequestId], references: [id], onDelete: SetNull)
  archivedViaLifecycleActionRequest MemberLifecycleActionRequest?  @relation("ArchivedViaMemberLifecycleActionRequest", fields: [archivedViaLifecycleActionRequestId], references: [id], onDelete: SetNull)

  // Family group: links primary adult members (e.g. spouses) for shared booking quick-add
  // @deprecated — use FamilyGroupMember join table instead
  familyGroupId String?
  familyGroup   FamilyGroup? @relation("FamilyGroupLegacy", fields: [familyGroupId], references: [id])

  // Many-to-many family group memberships via join table
  familyGroupMemberships FamilyGroupMember[]

  // Relations
  passwordResetTokens                        PasswordResetToken[]
  emailVerificationTokens                    EmailVerificationToken[]
  emailChangeTokens                          EmailChangeToken[]
  twoFactorEmailCodes                        TwoFactorEmailCode[]
  twoFactorRecoveryCodes                     TwoFactorRecoveryCode[]
  twoFactorSessionChallenges                 TwoFactorSessionChallenge[]
  subscriptions                              MemberSubscription[]
  memberSubscriptionsManuallyPaid            MemberSubscription[]                    @relation("MemberSubscriptionManualPaidBy")
  membershipChargesReceived                  MembershipSubscriptionCharge[]          @relation("MembershipChargeRecipient")
  membershipChargesConfirmed                 MembershipSubscriptionCharge[]          @relation("MembershipChargeConfirmer")
  membershipBillingExceptions                MembershipBillingException[]            @relation("MembershipBillingExceptionMember")
  seasonalMembershipAssignments              SeasonalMembershipAssignment[]             @relation("SeasonalMembershipAssignmentMember")
  seasonalMembershipAssignmentsAssigned      SeasonalMembershipAssignment[]             @relation("SeasonalMembershipAssignmentAssignedBy")
  accessRoles                                MemberAccessRole[]                         @relation("MemberAccessRoleMember")
  accessRolesAssigned                        MemberAccessRole[]                         @relation("MemberAccessRoleAssignedBy")
  bookings                                   Booking[]
  guestAppearances                           BookingGuest[]
  bookingChangeRequestsRequested             BookingChangeRequest[]                     @relation("BookingChangeRequestsRequested")
  bookingChangeRequestsReviewed              BookingChangeRequest[]                     @relation("BookingChangeRequestsReviewed")
  promoRedemptions                           PromoRedemption[]
  promoRedemptionAllocations                 PromoRedemptionAllocation[]
  promoCodeAssignments                       PromoCodeAssignment[]
  notificationPreference                     NotificationPreference?
  hutLeaderAssignments                       HutLeaderAssignment[]
  lodgeAccess                                MemberLodgeAccess[]
  lodgeAccessCreated                         MemberLodgeAccess[]                        @relation("MemberLodgeAccessCreatedBy")
  familyGroupRequests                        FamilyGroupJoinRequest[]                   @relation("FamilyGroupRequester")
  familyGroupInvitations                     FamilyGroupJoinRequest[]                   @relation("FamilyGroupInvitedMember")
  familyGroupLinkedRequests                  FamilyGroupJoinRequest[]                   @relation("FamilyGroupLinkedMember")
  familyGroupSubjectRequests                 FamilyGroupJoinRequest[]                   @relation("FamilyGroupSubjectMember")
  partnerInviteTokensCreated                 PartnerInviteToken[]                       @relation("PartnerInviteTokenCreatedBy")
  partnerLinksAsMemberA                      MemberPartnerLink[]                        @relation("PartnerLinkMemberA")
  partnerLinksAsMemberB                      MemberPartnerLink[]                        @relation("PartnerLinkMemberB")
  partnerLinksInitiated                      MemberPartnerLink[]                        @relation("PartnerLinkInitiatedBy")
  partnerLinksConfirmed                      MemberPartnerLink[]                        @relation("PartnerLinkConfirmedBy")
  partnerLinksAdminAssigned                  MemberPartnerLink[]                        @relation("PartnerLinkAssignedByAdmin")
  deletionRequests                           DeletionRequest[]
  credits                                    MemberCredit[]
  requestedCreditAdjustments                 MemberCredit[]                             @relation("RequestedAdminCredits")
  approvedCreditAdjustments                  MemberCredit[]                             @relation("ApprovedAdminCredits")
  adminCreditAdjustmentRequestsRequested     AdminCreditAdjustmentRequest[]             @relation("AdminCreditAdjustmentRequestsRequested")
  adminCreditAdjustmentRequestsReviewed      AdminCreditAdjustmentRequest[]             @relation("AdminCreditAdjustmentRequestsReviewed")
  bookingsCreatedOnBehalf                    Booking[]                                  @relation("BookingsCreatedBy")
  bookingsAdminReviewed                      Booking[]                                  @relation("BookingsAdminReviewed")
  bookingsAdminCapacityHeld                  Booking[]                                  @relation("BookingsAdminCapacityHeld")
  bookingsCapacityOverridden                 Booking[]                                  @relation("BookingsCapacityOverridden")
  bookingsWholeLodgeHeld                     Booking[]                                  @relation("BookingsWholeLodgeHeld")
  approvedBedAllocations                     BedAllocation[]                            @relation("BedAllocationApprover")
  refundRequests                             RefundRequest[]
  issueReports                               IssueReport[]
  adminCreditAdjustmentRequests              AdminCreditAdjustmentRequest[]             @relation("AdminCreditAdjustmentTarget")
  membershipCancellationRequestsRequested    MembershipCancellationRequest[]            @relation("MembershipCancellationRequestRequester")
  membershipCancellationRequestsReviewed     MembershipCancellationRequest[]            @relation("MembershipCancellationRequestReviewer")
  membershipCancellationParticipants         MembershipCancellationRequestParticipant[] @relation("MembershipCancellationParticipantMember")
  membershipCancellationParticipantsReviewed MembershipCancellationRequestParticipant[] @relation("MembershipCancellationParticipantReviewer")
  lifecycleActionRequestsRequested           MemberLifecycleActionRequest[]             @relation("MemberLifecycleActionRequester")
  lifecycleActionRequestsReviewed            MemberLifecycleActionRequest[]             @relation("MemberLifecycleActionReviewer")
  bookingsDeleted                            Booking[]                                  @relation("BookingsDeletedBy")
  groupBookingsOrganised                     GroupBooking[]
  groupBookingJoins                          GroupBookingJoin[]
  inductions                                 MemberInduction[]                          @relation("MemberInductions")
  inductionSignOffs                          MemberInductionSignOff[]                   @relation("InductionSignOffSigner")
  assignedInductionSigners                   MemberInductionAssignedSigner[]            @relation("AssignedInductionSigners")
  lockersAllocated                           Locker[]                                   @relation("LockerAllocatedMember")
  committeeAssignments                       CommitteeAssignment[]                      @relation("CommitteeAssignmentMember")
  committeeAssignmentsAssigned               CommitteeAssignment[]                      @relation("CommitteeAssignmentAssignedBy")

  @@index([email])
  @@index([xeroContactId])
  @@index([parentMemberId])
  @@index([secondaryParentId])
  @@index([familyGroupId])
  @@index([inheritEmailFromId])
  @@index([detailsConfirmedByMemberId])
  @@index([cancelledViaRequestId])
  @@index([cancelledAt])
  @@index([archivedViaLifecycleActionRequestId])
  @@index([archivedAt])
  @@index([canLogin])
  @@index([active])
  @@index([twoFactorEnabled])
  @@index([twoFactorLockedUntil])
  @@index([hutLeaderEligible])
}

model MemberAccessRole {
  id                 String      @id @default(cuid())
  memberId           String
  // Enum value for system roles and the seeded default bundles; NULL for
  // rows backed only by a custom AccessRoleDefinition. Seeded-bundle rows
  // carry both the enum value and roleDefinitionId for compatibility.
  role               AccessRole?
  roleDefinitionId   String?
  assignedByMemberId String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  member         Member                @relation("MemberAccessRoleMember", fields: [memberId], references: [id], onDelete: Cascade)
  assignedBy     Member?               @relation("MemberAccessRoleAssignedBy", fields: [assignedByMemberId], references: [id], onDelete: SetNull)
  roleDefinition AccessRoleDefinition? @relation(fields: [roleDefinitionId], references: [id], onDelete: Restrict)

  @@unique([memberId, role])
  @@unique([memberId, roleDefinitionId])
  @@index([role])
  @@index([roleDefinitionId])
  @@index([assignedByMemberId])
}

// Editable admin access-role definitions (bundle label, description, and the
// per-area permission matrix). Only editable/deletable roles are rows here;
// the protected system roles (ADMIN, LODGE, USER, ORG) stay code-defined and
// have no row. The six seeded defaults keep their legacy enum value in
// systemRole so existing MemberAccessRole enum rows resolve to them.
model AccessRoleDefinition {
  id              String               @id @default(cuid())
  key             String               @unique
  systemRole      AccessRole?          @unique
  label           String
  description     String               @db.Text
  overviewLevel   AdminPermissionLevel @default(NONE)
  bookingsLevel   AdminPermissionLevel @default(NONE)
  membershipLevel AdminPermissionLevel @default(NONE)
  financeLevel    AdminPermissionLevel @default(NONE)
  lodgeLevel      AdminPermissionLevel @default(NONE)
  contentLevel    AdminPermissionLevel @default(NONE)
  supportLevel    AdminPermissionLevel @default(NONE)
  sortOrder       Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  memberAssignments MemberAccessRole[]

  @@index([sortOrder])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  memberId  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  memberId  String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([memberId])
}

model EmailChangeToken {
  id        String   @id @default(cuid())
  memberId  String
  newEmail  String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([memberId])
}

model TwoFactorEmailCode {
  id        String   @id @default(cuid())
  memberId  String
  codeHash  String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([codeHash])
}

model TwoFactorRecoveryCode {
  id        String    @id @default(cuid())
  memberId  String
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([codeHash])
  @@index([usedAt])
}

// Single-use proof that a two-factor challenge succeeded. Minted server-side
// after code verification, consumed (deleted) by the Auth.js jwt callback, so
// a client-forged session update cannot flip twoFactorVerified.
model TwoFactorSessionChallenge {
  id        String   @id @default(cuid())
  memberId  String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([expiresAt])
}

model MemberApplication {
  id                    String            @id @default(cuid())
  applicantFirstName    String
  applicantLastName     String
  applicantEmail        String
  applicantDateOfBirth  DateTime?
  applicantPhone        String?
  applicantAddress      Json?
  familyMembers         Json?
  nominator1Email       String
  nominator2Email       String
  nominator1Id          String?
  nominator2Id          String?
  nominator1ConfirmedAt DateTime?
  nominator2ConfirmedAt DateTime?
  status                ApplicationStatus @default(PENDING_NOMINATORS)
  adminNotes            String?
  reviewedBy            String?
  reviewedAt            DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  nominationTokens NominationToken[]
  induction        MemberInduction?

  // Pending-application uniqueness is enforced by the manual partial unique index
  // MemberApplication_pending_applicantEmail_unique in Prisma migrations.
  @@index([applicantEmail])
  @@index([status, createdAt])
  @@index([nominator1Id])
  @@index([nominator2Id])
}

model NominationToken {
  id                String    @id @default(cuid())
  tokenHash         String    @unique
  applicationId     String
  nominatorMemberId String
  expiresAt         DateTime
  confirmedAt       DateTime?
  reminderCount     Int       @default(0)
  lastSentAt        DateTime?
  createdAt         DateTime  @default(now())

  application MemberApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([nominatorMemberId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([confirmedAt, expiresAt])
}

// Single-use, hash-at-rest bearer token that invites a partner who has no
// account yet to join a family group by email (#1682). Modelled on
// NominationToken: only the sha256 hash of the raw token is stored, the raw
// token travels once in the invite email, and the row is single-use via
// confirmedAt. The invitee registers through the normal membership process and
// then claims this token to be auto-filed/accepted as an ADULT_INVITE into the
// (approved) family group.
model PartnerInviteToken {
  id            String    @id @default(cuid())
  tokenHash     String    @unique
  familyGroupId String
  invitedEmail  String
  createdById   String
  expiresAt     DateTime
  confirmedAt   DateTime?
  reminderCount Int       @default(0)
  lastSentAt    DateTime?
  createdAt     DateTime  @default(now())
  // Opt-in (#1742): when true, claiming this token also forms a CONFIRMED
  // MemberPartnerLink between createdBy and the claimer — the claim is the
  // partner's consent. Never set retroactively; the inviter opts in at mint.
  createPartnerLink Boolean @default(false)

  familyGroup FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  createdBy   Member      @relation("PartnerInviteTokenCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([familyGroupId])
  @@index([createdById])
  @@index([expiresAt])
  @@index([invitedEmail])
}

// ---------------------------------------------------------------------------
// Membership Subscriptions
// ---------------------------------------------------------------------------

model MemberSubscription {
  id                   String             @id @default(cuid())
  memberId             String
  seasonYear           Int
  status               SubscriptionStatus @default(NOT_INVOICED)
  xeroInvoiceId        String?
  xeroInvoiceNumber    String?
  xeroOnlineInvoiceUrl String?
  paidAt               DateTime?
  // E14 (#1944): manual mark-paid provenance for clubs that do not use Xero (or
  // one-off cash payments). Set together by the finance:edit manual-payment
  // endpoint when a subscription is marked PAID outside the Xero pipeline, and
  // cleared together on reversal. Xero sync/webhook paths never touch a row
  // whose manuallyMarkedPaidAt is set while it carries no Xero invoice link, so
  // a manual PAID is never silently downgraded.
  manuallyMarkedPaidAt         DateTime?
  manuallyMarkedPaidByMemberId String?
  manualPaymentNote            String?   @db.VarChar(500)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Relations
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  manuallyMarkedPaidBy Member? @relation("MemberSubscriptionManualPaidBy", fields: [manuallyMarkedPaidByMemberId], references: [id], onDelete: SetNull)
  chargeCoverage MembershipSubscriptionChargeCoverage?

  @@unique([memberId, seasonYear])
  @@index([memberId])
  @@index([seasonYear])
  @@index([seasonYear, status])
  @@index([manuallyMarkedPaidByMemberId])
}

// Immutable financial snapshot for one membership subscription invoice decision.
// Only operational delivery fields (status/Xero/email metadata) may change after
// creation; fee, coverage, recipient and proration columns never do.
model MembershipSubscriptionCharge {
  id                    String                             @id @default(cuid())
  idempotencyKey        String                             @unique
  seasonYear            Int
  source                MembershipSubscriptionChargeSource
  status                MembershipSubscriptionChargeStatus @default(QUEUED)
  membershipAnnualFeeId String?
  membershipTypeId      String
  membershipTypeKey     String
  membershipTypeName    String
  billingBasis          MembershipFeeBillingBasis
  prorationRule         MembershipFeeProrationRule
  annualAmountCents     Int
  chargedAmountCents    Int
  coveredMonths         Int
  decisionDate          DateTime                           @db.Date
  coverageStart         DateTime                           @db.Date
  coverageEnd           DateTime                           @db.Date
  familyGroupId         String?
  recipientMemberId     String
  recipientName         String
  recipientEmail        String
  dueDays               Int
  xeroAccountCode       String?
  xeroItemCode          String?
  invoiceReference      String                             @unique
  xeroInvoiceId         String?                            @unique
  xeroInvoiceNumber     String?
  xeroInvoiceUrl        String?
  xeroInvoiceAdopted    Boolean                            @default(false)
  invoicePersistedAt    DateTime?
  emailAttemptCount     Int                                @default(0)
  emailLastAttemptAt    DateTime?
  emailSentAt           DateTime?
  lastErrorCode         String?
  lastErrorMessage      String?
  confirmedByMemberId   String?
  confirmedAt           DateTime?
  createdAt             DateTime                           @default(now())
  updatedAt             DateTime                           @updatedAt

  recipient   Member   @relation("MembershipChargeRecipient", fields: [recipientMemberId], references: [id], onDelete: Restrict)
  confirmedBy Member?  @relation("MembershipChargeConfirmer", fields: [confirmedByMemberId], references: [id], onDelete: SetNull)
  coverage    MembershipSubscriptionChargeCoverage[]

  @@index([seasonYear, status, createdAt])
  @@index([recipientMemberId, seasonYear])
  @@index([familyGroupId, seasonYear])
  @@unique([seasonYear, membershipTypeId, familyGroupId], map: "MembershipCharge_family_type_year_key")
}

model MembershipSubscriptionChargeCoverage {
  id             String   @id @default(cuid())
  chargeId       String
  subscriptionId String   @unique
  memberId       String
  memberName     String
  createdAt      DateTime @default(now())

  charge       MembershipSubscriptionCharge @relation(fields: [chargeId], references: [id], onDelete: Restrict)
  subscription MemberSubscription            @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@unique([chargeId, subscriptionId], map: "MembershipChargeCoverage_charge_subscription_key")
  @@index([chargeId])
  @@index([memberId, createdAt])
}

model MembershipBillingException {
  id             String                           @id @default(cuid())
  fingerprint    String                           @unique
  seasonYear     Int
  source         MembershipSubscriptionChargeSource
  status         MembershipBillingExceptionStatus @default(OPEN)
  code           String
  message        String
  memberId       String?
  familyGroupId  String?
  membershipTypeId String?
  context        Json?
  firstSeenAt    DateTime                         @default(now())
  lastSeenAt     DateTime                         @default(now())
  resolvedAt     DateTime?
  createdAt      DateTime                         @default(now())
  updatedAt      DateTime                         @updatedAt

  member Member? @relation("MembershipBillingExceptionMember", fields: [memberId], references: [id], onDelete: SetNull)

  @@index([status, seasonYear, lastSeenAt])
  @@index([memberId, status])
  @@index([familyGroupId, status])
}

model MembershipSubscriptionBillingSettings {
  id                String            @id @default("default")
  invoiceDueDays    Int               @default(30)
  // Club billing model. BILL_FAMILY_VIA_BILLING_MEMBER (the default, preserving
  // pre-#159 behaviour) invoices each family once via its nominated billing
  // member and allows PER_FAMILY fee schedules. BILL_MEMBERS_INDIVIDUALLY
  // invoices every member directly, hides the family-billing surface, and
  // disallows PER_FAMILY schedules.
  familyBillingMode FamilyBillingMode @default(BILL_FAMILY_VIA_BILLING_MEMBER)
  updatedByMemberId String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

// ---------------------------------------------------------------------------
// Seasonal Membership Types
// ---------------------------------------------------------------------------

model MembershipType {
  id                   String                             @id @default(cuid())
  // Stable identifier used by seeds, migrations, and follow-up enforcement
  // work. Display names can change without changing this key.
  key                  String                             @unique
  name                 String
  description          String?                            @db.Text
  publicDescription    String?                            @db.Text
  publiclyListed       Boolean                            @default(false)
  isActive             Boolean                            @default(true)
  isBuiltIn            Boolean                            @default(false)
  bookingBehavior      MembershipTypeBookingBehavior      @default(MEMBER_RATE)
  subscriptionBehavior MembershipTypeSubscriptionBehavior @default(REQUIRED)
  // When true, this type's hut nightly rates are keyed per age tier; when
  // false, the type prices from a single flat rate (one NULL-ageTier
  // MembershipTypeSeasonRate row per season). Day-one backfill copies the
  // per-tier legacy rates, so every type starts age-keyed (#1930, E4).
  ageGroupsApply       Boolean                            @default(true)
  sortOrder            Int                                @default(0)
  createdAt            DateTime                           @default(now())
  updatedAt            DateTime                           @updatedAt

  assignments           SeasonalMembershipAssignment[]
  allowedAgeTiers       MembershipTypeAgeTier[]
  xeroContactGroupRules XeroContactGroupRule[]
  annualFees            MembershipAnnualFee[]
  seasonRates           MembershipTypeSeasonRate[]

  @@index([isActive, sortOrder])
  @@index([sortOrder])
}

model MembershipAnnualFee {
  id               String                       @id @default(cuid())
  membershipTypeId String
  amountCents      Int
  billingBasis     MembershipFeeBillingBasis
  prorationRule    MembershipFeeProrationRule   @default(NONE)
  effectiveFrom    DateTime                     @db.Date
  effectiveTo      DateTime?                    @db.Date
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  membershipType MembershipType @relation(fields: [membershipTypeId], references: [id], onDelete: Restrict)

  @@unique([membershipTypeId, effectiveFrom])
  @@index([membershipTypeId, effectiveFrom, effectiveTo], map: "MembershipAnnualFee_effective_lookup_idx")
}

model EntranceFee {
  id            String              @id @default(cuid())
  category      EntranceFeeCategory
  amountCents   Int
  effectiveFrom DateTime            @db.Date
  effectiveTo   DateTime?           @db.Date
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([category, effectiveFrom])
  @@index([category, effectiveFrom, effectiveTo])
}

model MembershipTypeAgeTier {
  id               String   @id @default(cuid())
  membershipTypeId String
  ageTier          AgeTier
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  membershipType MembershipType @relation(fields: [membershipTypeId], references: [id], onDelete: Cascade)

  @@unique([membershipTypeId, ageTier])
  @@index([ageTier])
}

model XeroContactGroupRule {
  id               String                   @id @default(cuid())
  membershipTypeId String?
  ageTier          AgeTier?
  mode             XeroContactGroupRuleMode
  groupId          String
  groupName        String?
  isActive         Boolean                  @default(true)
  sortOrder        Int                      @default(0)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  membershipType MembershipType? @relation(fields: [membershipTypeId], references: [id], onDelete: Cascade)

  @@index([membershipTypeId])
  @@index([ageTier])
  @@index([mode, isActive, sortOrder])
  @@index([groupId])
  // Dedupe of identical rule shapes is enforced by a raw-SQL partial unique
  // index (E8, #1934) — Prisma cannot express NULLS NOT DISTINCT, so the index
  // lives in the migration and is recorded in prisma/partial-unique-indexes.tsv:
  //   XeroContactGroupRule_shape_unique on
  //   (membershipTypeId, ageTier, mode, groupId) NULLS NOT DISTINCT.
  // App-side rule CRUD enforces the same dedupe for friendly errors.
}

// Single-row ("default") club setting selecting the Xero member-grouping mode
// (E8, #1934). Governs syncManagedXeroContactGroupForMember and the
// cancellation-path managed universe. Backfilled to MEMBERSHIP_TYPE_AND_AGE for
// installs that had any age-tier Xero group config (Tokoroa), otherwise NONE.
model XeroGroupingSettings {
  id                String                 @id @default("default")
  mode              XeroMemberGroupingMode @default(NONE)
  updatedByMemberId String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([updatedByMemberId])
}

model SeasonalMembershipAssignment {
  id                 String                     @id @default(cuid())
  memberId           String
  seasonYear         Int
  membershipTypeId   String
  applyFrom          DateTime?                  @db.Date
  assignedByMemberId String?
  source             MembershipAssignmentSource @default(ADMIN)
  sourceDetail       String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  member         Member         @relation("SeasonalMembershipAssignmentMember", fields: [memberId], references: [id], onDelete: Cascade)
  membershipType MembershipType @relation(fields: [membershipTypeId], references: [id], onDelete: Restrict)
  assignedBy     Member?        @relation("SeasonalMembershipAssignmentAssignedBy", fields: [assignedByMemberId], references: [id], onDelete: SetNull)

  @@unique([memberId, seasonYear])
  @@index([seasonYear])
  @@index([membershipTypeId])
  @@index([seasonYear, membershipTypeId])
  @@index([assignedByMemberId])
}

// ---------------------------------------------------------------------------
// Membership Cancellation Foundation
// ---------------------------------------------------------------------------

model MembershipCancellationRequest {
  id                  String                              @id @default(cuid())
  requestedByMemberId String?
  status              MembershipCancellationRequestStatus @default(REQUESTED)
  reason              String?
  adminNote           String?
  submittedAt         DateTime                            @default(now())
  reviewedByMemberId  String?
  reviewedAt          DateTime?
  completedAt         DateTime?
  createdAt           DateTime                            @default(now())
  updatedAt           DateTime                            @updatedAt

  requestedBy      Member?                                    @relation("MembershipCancellationRequestRequester", fields: [requestedByMemberId], references: [id], onDelete: SetNull)
  reviewedBy       Member?                                    @relation("MembershipCancellationRequestReviewer", fields: [reviewedByMemberId], references: [id], onDelete: SetNull)
  participants     MembershipCancellationRequestParticipant[]
  cancelledMembers Member[]                                   @relation("CancelledViaMembershipCancellationRequest")

  @@index([requestedByMemberId])
  @@index([reviewedByMemberId])
  @@index([status, createdAt])
  @@index([submittedAt])
}

model MembershipCancellationRequestParticipant {
  id                         String                                  @id @default(cuid())
  requestId                  String
  memberId                   String
  status                     MembershipCancellationParticipantStatus @default(REQUESTED)
  reason                     String?
  adminNote                  String?
  confirmationTokenHash      String?                                 @unique(map: "MCRParticipant_confirmationTokenHash_key")
  confirmationTokenExpiresAt DateTime?
  confirmedAt                DateTime?
  declinedAt                 DateTime?
  cancelledAt                DateTime?
  reviewedByMemberId         String?
  reviewedAt                 DateTime?
  createdAt                  DateTime                                @default(now())
  updatedAt                  DateTime                                @updatedAt

  request    MembershipCancellationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  member     Member                        @relation("MembershipCancellationParticipantMember", fields: [memberId], references: [id], onDelete: Restrict)
  reviewedBy Member?                       @relation("MembershipCancellationParticipantReviewer", fields: [reviewedByMemberId], references: [id], onDelete: SetNull, map: "MCRParticipant_reviewedByMemberId_fkey")

  @@unique([requestId, memberId])
  @@index([requestId, status])
  @@index([memberId, status])
  @@index([reviewedByMemberId])
  @@index([confirmationTokenExpiresAt], map: "MCRParticipant_confirmationTokenExpiresAt_idx")
  @@index([cancelledAt])
}

model MemberLifecycleActionRequest {
  id                  String                             @id @default(cuid())
  // No FK relation on memberId by design: the snapshot must survive the
  // member being deleted so the audit trail is preserved. See the
  // foundation migration for the original rationale.
  memberId            String
  action              MemberLifecycleAction
  status              MemberLifecycleActionRequestStatus @default(REQUESTED)
  reason              String
  reviewNote          String?
  memberSnapshot      Json?
  requestedByMemberId String?
  requestedAt         DateTime                           @default(now())
  reviewedByMemberId  String?
  reviewedAt          DateTime?
  processedAt         DateTime?
  createdAt           DateTime                           @default(now())
  updatedAt           DateTime                           @updatedAt

  requestedBy     Member?  @relation("MemberLifecycleActionRequester", fields: [requestedByMemberId], references: [id], onDelete: SetNull)
  reviewedBy      Member?  @relation("MemberLifecycleActionReviewer", fields: [reviewedByMemberId], references: [id], onDelete: SetNull)
  archivedMembers Member[] @relation("ArchivedViaMemberLifecycleActionRequest")

  @@index([memberId, action, status])
  @@index([requestedByMemberId])
  @@index([reviewedByMemberId])
  @@index([status, requestedAt])
  @@index([action, status])
}

// ---------------------------------------------------------------------------
// Seasons & Rates
// ---------------------------------------------------------------------------

model Season {
  id        String     @id @default(cuid())
  name      String
  type      SeasonType
  startDate DateTime   @db.Date
  endDate   DateTime   @db.Date
  active    Boolean    @default(true)
  lodgeId   String     @default(dbgenerated("default_lodge_id()"))
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  // `rates` is the legacy member/non-member boolean-keyed rate table. It is
  // retained (frozen, read only by the public {{hut-fees}} embed) after the
  // E4 re-key (#1930); the authoritative pricing rows now live in
  // `membershipTypeRates`. E13 drops `rates` after a release soak.
  rates              SeasonRate[]
  membershipTypeRates MembershipTypeSeasonRate[]
  lodge Lodge        @relation(fields: [lodgeId], references: [id], onDelete: Restrict)

  @@index([startDate, endDate])
  @@index([lodgeId])
}

model SeasonRate {
  id                 String  @id @default(cuid())
  seasonId           String
  ageTier            AgeTier
  isMember           Boolean
  pricePerNightCents Int

  // Relations
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, ageTier, isMember])
  @@index([seasonId])
}

// Hut nightly rate keyed by membership type (#1930, E4). Replaces the
// member/non-member boolean key on SeasonRate: each MEMBER_RATE membership
// type carries its own rate rows, non-members price via the built-in
// NON_MEMBER type, and NON_MEMBER_RATE/BLOCK_BOOKING types deliberately carry
// zero own rows (D2 invariant). `ageTier` is nullable: a per-age-tier type
// has one row per tier; a flat type (ageGroupsApply=false) has a single
// NULL-ageTier row. Postgres treats NULLs as distinct in the composite
// unique, so a companion raw-SQL partial unique index
// (WHERE "ageTier" IS NULL) enforces one flat row per (season, type) — it
// lives in the migration and prisma/partial-unique-indexes.tsv.
model MembershipTypeSeasonRate {
  id                 String   @id @default(cuid())
  seasonId           String
  membershipTypeId   String
  ageTier            AgeTier?
  pricePerNightCents Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  season         Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  membershipType MembershipType @relation(fields: [membershipTypeId], references: [id], onDelete: Cascade)

  @@unique([seasonId, membershipTypeId, ageTier])
  @@index([seasonId])
  @@index([membershipTypeId])
}

// ---------------------------------------------------------------------------
// Bookings
// ---------------------------------------------------------------------------

model Booking {
  id                        String             @id @default(cuid())
  memberId                  String
  checkIn                   DateTime           @db.Date
  checkOut                  DateTime           @db.Date
  status                    BookingStatus      @default(PENDING)
  totalPriceCents           Int
  discountCents             Int                @default(0)
  promoAdjustmentCents      Int                @default(0)
  finalPriceCents           Int
  hasNonMembers             Boolean            @default(false)
  // When true, the member asked us to cancel the whole booking if their
  // non-member guests cannot be accommodated, instead of the default partial
  // bump (drop the non-members, keep the members). Both happen pre-charge.
  cancelIfGuestsBumped      Boolean            @default(false)
  nonMemberHoldUntil        DateTime?
  // Split-booking group link (issue #738). A mixed member/non-member party is
  // stored as two bookings: a member booking that is paid up front and holds
  // capacity (the parent, parentBookingId = null) plus a provisional
  // non-member booking that holds nothing (the child, parentBookingId = the
  // member booking). Pure parties and the flagged "only book if my guests can
  // come" path stay a single booking with parentBookingId = null.
  parentBookingId           String?
  // Group booking, ORGANISER_PAYS mode: a joiner's child booking carries its
  // real price but is settled by the organiser as part of one combined bill, so
  // the joiner is never billed for it. When true the joiner cannot pay this
  // booking themselves; the organiser-settlement flow collects the group total
  // and marks these PAID. Defaults false for every normal (each-pays) booking.
  organiserSettled          Boolean            @default(false)
  draftExpiresAt            DateTime?
  notes                     String?            @db.VarChar(500)
  expectedArrivalTime       String?            @db.VarChar(5)
  requestedRoomId           String?
  preArrivalReminderSentAt  DateTime?
  createdById               String? // Admin who created this booking on behalf of the member
  requiresAdminReview       Boolean            @default(false)
  adminReviewReason         String?            @db.VarChar(300)
  memberReviewJustification String?            @db.VarChar(1000)
  adminReviewStatus         AdminReviewStatus?
  adminReviewNotes          String?            @db.VarChar(2000)
  adminReviewedById         String?
  adminReviewedAt           DateTime?
  waitlistPosition          Int?
  waitlistOfferedAt         DateTime?
  waitlistOfferExpiresAt    DateTime?
  // Cross-lodge waitlist offers (ADR-004): set only when the current offer
  // is for an alternate lodge the member opted into — the offered lodge and
  // the price quoted for it. Null for same-lodge offers, which behave
  // exactly as before ADR-004. Money in integer cents.
  waitlistOfferedLodgeId    String?
  waitlistOfferedPriceCents Int?
  deletedAt                 DateTime?
  deletedById               String?
  deletedReason             String?            @db.VarChar(500)
  // NOT NULL (migration 20260708001100): a default_lodge_id() column default
  // fills omitted-column writes so enforcement was outage-free. One booking
  // belongs to exactly one lodge (ADR-001 resolved question 1).
  lodgeId                   String             @default(dbgenerated("default_lodge_id()"))
  // Admin capacity hold (#1764): while set AND the booking is PAYMENT_PENDING,
  // the booking consumes lodge capacity exactly as if it were in a naturally
  // capacity-holding status (see capacityHoldingBookingFilter). Orthogonal to
  // the lifecycle status — the status keeps meaning what it means. Cleared by
  // Admin Unhold and by every cancel path; left set-but-inert once the booking
  // reaches a naturally-holding status (the status disjunct then holds the
  // beds, so capacity is never double-counted).
  adminCapacityHoldAt         DateTime?
  adminCapacityHoldByMemberId String?
  // Persisted capacity override (#1771): set when this booking was deliberately
  // admitted ABOVE the lodge ceiling via an explicit admin over-capacity confirm
  // (#1668/#1695/#1767 create, date/batch modify, waitlist force-confirm, #1764
  // admin capacity-hold). Read by every payment-time / settlement capacity
  // re-check (see bookingHasCapacityOverride) so a *priced* overridden booking is
  // never cancelled/refunded, 409'd, or bumped when payment lands over capacity.
  // Reflects "is this a deliberate overbook on its CURRENT nights": one-shot
  // admissions (create, force-confirm, capacity-hold) stamp it; date/batch
  // modification RECONCILES it (re-stamps if the new range is still over
  // capacity, clears it if the change moved back within capacity) since those
  // paths re-evaluate capacity on the new nights. Not cleared on cancel — a
  // cancelled booking never re-enters a re-check, so the audit fact is kept.
  capacityOverriddenAt         DateTime?
  capacityOverriddenByMemberId String?
  // Exclusive whole-lodge hold (#117 / epic #116, ADR-001): when true this
  // booking reserves SOLE OCCUPANCY of the lodge for its nights. The capacity
  // engine (#118) hard-blocks any other admission on a held night — independent
  // of headcount and bed allocation, and NOT bypassable by the admin
  // over-capacity override. Set by an admin (audited via the two fields below,
  // mirroring the capacity-override audit pattern) or by approving a
  // BookingRequest whose exclusivityRequested is set. Additive/expand-only;
  // default false keeps every existing booking non-exclusive.
  wholeLodgeHold               Boolean            @default(false)
  wholeLodgeHoldAt             DateTime?
  wholeLodgeHoldByMemberId     String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  member                      Member                          @relation(fields: [memberId], references: [id], onDelete: Restrict)
  lodge                       Lodge                           @relation(fields: [lodgeId], references: [id], onDelete: Restrict)
  waitlistOfferedLodge        Lodge?                          @relation("BookingWaitlistOfferedLodge", fields: [waitlistOfferedLodgeId], references: [id], onDelete: SetNull)
  waitlistAlternateLodges     BookingWaitlistAlternateLodge[]
  createdBy                   Member?                         @relation("BookingsCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  deletedBy                   Member?                         @relation("BookingsDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  adminReviewedBy             Member?                         @relation("BookingsAdminReviewed", fields: [adminReviewedById], references: [id], onDelete: SetNull)
  adminCapacityHoldBy         Member?                         @relation("BookingsAdminCapacityHeld", fields: [adminCapacityHoldByMemberId], references: [id], onDelete: SetNull)
  capacityOverriddenBy        Member?                         @relation("BookingsCapacityOverridden", fields: [capacityOverriddenByMemberId], references: [id], onDelete: SetNull)
  wholeLodgeHoldBy            Member?                         @relation("BookingsWholeLodgeHeld", fields: [wholeLodgeHoldByMemberId], references: [id], onDelete: SetNull)
  requestedRoom               LodgeRoom?                      @relation("BookingRequestedRoom", fields: [requestedRoomId], references: [id], onDelete: SetNull)
  parentBooking               Booking?                        @relation("BookingGroup", fields: [parentBookingId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  linkedBookings              Booking[]                       @relation("BookingGroup")
  guests                      BookingGuest[]
  payment                     Payment?
  choreAssignments            ChoreAssignment[]
  promoRedemption             PromoRedemption?
  promoRedemptionAllocations  PromoRedemptionAllocation[]
  promoRedemptionGuestTargets PromoRedemptionGuestTarget[]
  modifications               BookingModification[]
  changeRequests              BookingChangeRequest[]
  creditsFromCancellation     MemberCredit[]                  @relation("CreditSource")
  creditsApplied              MemberCredit[]                  @relation("CreditApplied")
  refundRequests              RefundRequest[]
  paymentRecoveryOperations   PaymentRecoveryOperation[]
  bedAllocations              BedAllocation[]
  // Present when this booking was created from a public BookingRequest.
  originBookingRequest        BookingRequest?                 @relation("BookingRequestConvertedBooking")
  // Present while a public BookingRequest has been capacity-held by an admin
  // before the requester accepts a quote. Acceptance converts this row rather
  // than creating a duplicate booking.
  heldForBookingRequest       BookingRequest?                 @relation("BookingRequestHeldBooking")
  paymentLinks                PaymentLink[]
  // Durable per-transition fact store (issue #740). Unlike AuditLog these rows
  // are never retention-pruned, so booking/payment-link narratives survive.
  events                      BookingEvent[]
  // Group booking this booking anchors as organiser, and the join row that
  // created this booking as a group child (issue: group-booking join code).
  groupBookingAsOrganiser     GroupBooking?                   @relation("GroupBookingOrganiser")
  groupBookingJoin            GroupBookingJoin?               @relation("GroupBookingJoinBooking")

  @@index([memberId])
  @@index([createdById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([checkIn, checkOut])
  @@index([status])
  @@index([memberId, status])
  @@index([memberId, status, checkIn])
  @@index([status, createdAt])
  @@index([status, deletedAt, updatedAt])
  @@index([status, deletedAt, checkIn, checkOut])
  @@index([status, checkIn, checkOut, createdAt])
  @@index([status, preArrivalReminderSentAt, checkIn])
  @@index([adminReviewStatus, createdAt])
  @@index([adminReviewedById])
  @@index([adminCapacityHoldByMemberId])
  @@index([capacityOverriddenByMemberId])
  @@index([wholeLodgeHoldByMemberId])
  @@index([requestedRoomId])
  @@index([parentBookingId])
  @@index([lodgeId])
}

// Durable booking-lifecycle event store (issue #740). One row per transition
// (created, paid, confirmed, bumped, cancelled, refunded, credited). Unlike
// AuditLog these rows are never retention-pruned: booking and payment-link
// narratives are rendered from them so the wording survives audit pruning.
enum BookingEventType {
  CREATED
  MEMBER_PAID
  NON_MEMBER_CONFIRMED
  BUMPED
  CANCELLED
  REFUNDED
  CREDITED
}

model BookingEvent {
  id            String           @id @default(cuid())
  bookingId     String
  type          BookingEventType
  occurredAt    DateTime         @default(now())
  // Member whose action drove the transition (member, admin, or null for cron).
  actorMemberId String?
  // Money moved by this transition, integer cents (paid/refunded/credited).
  amountCents   Int?
  reason        String?          @db.VarChar(500)
  // Frozen facts that must not be recomputed later: cancellation policy summary
  // + retained amount, bump reason, refund method/percentage, etc.
  snapshot      Json?
  createdAt     DateTime         @default(now())

  // Restrict (not Cascade) keeps the no-cascade-off-Booking design used across
  // this schema; the only hard-delete path (draft cleanup) removes events
  // explicitly first. Soft-deleted bookings keep their row, so events survive.
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict)

  @@index([bookingId, occurredAt])
  @@index([type])
}

model BookingGuest {
  id         String    @id @default(cuid())
  bookingId  String
  firstName  String
  lastName   String
  ageTier    AgeTier
  isMember   Boolean   @default(false)
  memberId   String?
  stayStart  DateTime  @db.Date
  stayEnd    DateTime  @db.Date
  priceCents Int
  // Snapshot of the membership type whose rate rows priced this guest (#1930,
  // E4). Persisted at pricing time by the rate resolver and read by Xero line
  // building to pick the item code. NOT write-once: modify/reprice flows
  // recompute and overwrite it for repriced guests; locked nights keep the
  // price and the stale snapshot untouched. A NULL snapshot (pre-refactor
  // bookings) falls back isMember → FULL/NON_MEMBER at read time — kept
  // forever. Deliberately a bare column (no FK): the snapshot must survive
  // even if a custom type is later deleted.
  rateMembershipTypeId String?
  arrivedAt  DateTime?
  departedAt DateTime?
  createdAt  DateTime  @default(now())

  // Relations
  booking                     Booking                      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  member                      Member?                      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  choreAssignments            ChoreAssignment[]
  choreTokens                 GuestChoreToken[]
  bedAllocations              BedAllocation[]
  promoRedemptionGuestTargets PromoRedemptionGuestTarget[]
  // Per-night stay records (issue #713). A guest may stay non-contiguous
  // nights within one booking; each included night is one BookingGuestNight
  // row. stayStart/stayEnd above remain the derived min/max envelope, kept in
  // sync on every write. Reads outside the creation + manage-guests editing
  // flows keep using the envelope.
  nights                      BookingGuestNight[]

  @@index([bookingId])
  @@index([bookingId, stayStart, stayEnd])
  @@index([stayStart, stayEnd])
  @@index([memberId])
}

// Per-night stay record for a booking guest (issue #713). One row per night
// the guest is actually staying, with that night's price in integer cents.
// Non-contiguous stays are represented as a sparse set of these rows; the
// guest's stayStart/stayEnd envelope is the min/max of the set.
model BookingGuestNight {
  id             String   @id @default(cuid())
  bookingGuestId String
  stayDate       DateTime @db.Date
  priceCents     Int
  createdAt      DateTime @default(now())

  bookingGuest BookingGuest @relation(fields: [bookingGuestId], references: [id], onDelete: Cascade)

  @@unique([bookingGuestId, stayDate])
  @@index([stayDate])
}

// ---------------------------------------------------------------------------
// Group bookings (shareable join code)
// ---------------------------------------------------------------------------
// A member (the organiser) opens one of their bookings as a private group event
// (e.g. a birthday party at the lodge) and shares a short join code. Members and
// non-members open the /join/[code] link and add themselves: each joiner becomes
// their own child Booking linked to the organiser booking via parentBookingId
// (the existing split-booking relation), so capacity, pricing, payment, and
// cancellation all reuse the per-booking machinery. The organiser chooses whether
// each joiner pays for their own beds (EACH_PAYS_OWN) or the organiser settles the
// whole bill and joiners are registered at $0 (ORGANISER_PAYS). Joins are checked
// against remaining lodge capacity at join time under the same advisory lock as
// every other creation path; there is no pre-held block.

enum GroupBookingPaymentMode {
  EACH_PAYS_OWN
  ORGANISER_PAYS
}

enum GroupBookingStatus {
  OPEN
  CLOSED
  CANCELLED
}

model GroupBooking {
  id                 String                  @id @default(cuid())
  organiserBookingId String                  @unique
  organiserMemberId  String
  joinCode           String                  @unique
  paymentMode        GroupBookingPaymentMode
  status             GroupBookingStatus      @default(OPEN)
  joinDeadline       DateTime?
  maxJoiners         Int?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  organiserBooking Booking                 @relation("GroupBookingOrganiser", fields: [organiserBookingId], references: [id], onDelete: Cascade)
  organiserMember  Member                  @relation(fields: [organiserMemberId], references: [id], onDelete: Restrict)
  joins            GroupBookingJoin[]
  settlement       GroupBookingSettlement?

  @@index([organiserMemberId])
  @@index([status, joinDeadline])
}

model GroupBookingJoin {
  id             String  @id @default(cuid())
  groupBookingId String
  bookingId      String? @unique
  joinerMemberId String?
  isMember       Boolean @default(false)

  // Non-member verify handshake (mirrors BookingRequest). Contact, the guest
  // snapshot, and a SHA-256 token hash are held here before any child booking
  // exists; the booking is created only after the joiner confirms their email.
  contactFirstName           String?   @db.VarChar(100)
  contactLastName            String?   @db.VarChar(100)
  contactEmail               String?   @db.VarChar(200)
  contactPhone               String?   @db.VarChar(30)
  guestsSnapshot             Json?
  verificationTokenHash      String?   @unique
  verificationTokenExpiresAt DateTime?
  verifiedAt                 DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupBooking GroupBooking @relation(fields: [groupBookingId], references: [id], onDelete: Cascade)
  booking      Booking?     @relation("GroupBookingJoinBooking", fields: [bookingId], references: [id], onDelete: SetNull)
  joinerMember Member?      @relation(fields: [joinerMemberId], references: [id], onDelete: SetNull)

  // One roster row per member per group (#1039 item 2). Non-member joins
  // carry a NULL joinerMemberId and are unaffected (NULLs are distinct); a
  // member re-joining after cancellation reuses their row inside the booking
  // transaction rather than creating a duplicate.
  @@unique([groupBookingId, joinerMemberId])
  @@index([groupBookingId])
  @@index([verificationTokenExpiresAt])
  @@index([contactEmail])
}

// ORGANISER_PAYS settlement: one combined Stripe payment by which the organiser
// settles every organiser-settled child booking in the group as a single bill.
// At settle time the children are committed to CONFIRMED (capacity held, like a
// pay-on-account invoice, issue #709); this record holds the combined
// PaymentIntent and flips them all to PAID exactly once on webhook success.
model GroupBookingSettlement {
  id                    String        @id @default(cuid())
  groupBookingId        String        @unique
  stripePaymentIntentId String?       @unique
  stripeCustomerId      String?
  // How the organiser settles: a Stripe PaymentIntent (default) or one combined
  // Xero invoice paid by Internet Banking. For the Internet Banking source the
  // raised invoice is tracked here so inbound Xero reconciliation can flip the
  // joiner children to PAID when it is settled.
  source                PaymentSource @default(STRIPE)
  xeroInvoiceId         String?
  xeroInvoiceNumber     String?
  amountCents           Int
  status                PaymentStatus @default(PENDING)
  // Per-child refund plan {childId: cents} persisted on the organiser-cancel
  // first run so a crash-interrupted re-drive applies the RECORDED amounts
  // (never recomputes — tier drift is unsafe). #1236
  refundPlan            Json?
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  groupBooking GroupBooking @relation(fields: [groupBookingId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

// ---------------------------------------------------------------------------
// Public Booking Requests (non-member request-to-book / request-for-price)
// ---------------------------------------------------------------------------

model BookingRequest {
  id               String               @id @default(cuid())
  type             BookingRequestType   @default(GENERAL)
  status           BookingRequestStatus @default(NEW)
  contactFirstName String               @db.VarChar(100)
  contactLastName  String               @db.VarChar(100)
  contactEmail     String               @db.VarChar(200)
  contactPhone     String?              @db.VarChar(30)
  checkIn          DateTime             @db.Date
  checkOut         DateTime             @db.Date
  // Guest list snapshot: array of { firstName, lastName, ageTier }.
  // For SCHOOL requests this holds the generated bulk list: teachers as
  // named ADULT guests plus "School Child 1..N" rows at the requested tiers.
  guests           Json
  message          String?              @db.VarChar(1000)

  // Exclusive whole-lodge hold — request path (#117 / epic #116, ADR-001). A
  // requester (school/group front-door) can ask for sole occupancy of the
  // lodge. This is only the REQUEST signal; an admin approving the request may
  // set Booking.wholeLodgeHold on the resulting booking (the flag itself is the
  // admin capacity action). Booking-generic; "school" is just the wording.
  // Additive/expand-only; default false.
  exclusivityRequested Boolean            @default(false)

  // SCHOOL variant only. The school is the invoiced party / Xero contact.
  schoolName         String?                   @db.VarChar(200)
  // Teacher contact snapshot: array of { firstName, lastName, email? }.
  // Each becomes a non-login Member with a HutLeaderAssignment on approval.
  teachers           Json?
  // School quote intake preference. GENERAL requests leave this null.
  cateringPreference SchoolCateringPreference?
  // Admin-linked member guests: array of { guestIndex, memberId }. Linked
  // adults are copied into BookingGuest.memberId on hold/acceptance.
  linkedGuestMembers Json?

  // Lodge the stay is requested at (lodge-scoping contract, audited
  // 2026-07-03). Null rows predate the column and mean the club's default
  // lodge; readers resolve request.lodgeId ?? default. New requests always
  // set it (the public forms offer a choice only when a second active
  // lodge exists, ADR-002).
  lodgeId String?

  // Indicative pricing shown on the public form (when enabled) at submit time.
  indicativePriceCents Int?
  // Officer-set price the requester is asked to pay on approval.
  priceCents           Int?

  // Email verification (SHA-256 hash only; raw token is emailed once).
  verificationTokenHash      String?   @unique
  verificationTokenExpiresAt DateTime?
  verifiedAt                 DateTime?

  // School attendee confirmation (#1101, SCHOOL requests with a converted
  // booking). SHA-256 hash only; the raw token is emailed and rotated on
  // each reminder. Confirmation is the school contact's explicit action.
  attendeeConfirmationTokenHash      String?   @unique
  attendeeConfirmationTokenExpiresAt DateTime?
  attendeeConfirmationLastSentAt     DateTime?
  attendeesConfirmedAt               DateTime?

  pricedByMemberId   String?
  pricedAt           DateTime?
  reviewedByMemberId String?
  reviewedAt         DateTime?
  declineReason      String?   @db.VarChar(2000)

  convertedBookingId    String?   @unique
  convertedMemberId     String?
  heldBookingId         String?   @unique
  acceptedQuoteId       String?   @unique
  acceptedQuoteOptionId String?
  acceptedQuoteSnapshot Json?
  acceptedPriceCents    Int?
  acceptedAt            DateTime?
  responseMessage       String?   @db.VarChar(2000)
  responseMessageAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Optimistic-concurrency counter for the held-request conversion fences
  // (#1923). Every mutating write of this row increments it (enforced by the
  // version-increment source contract), and the conversion claims fence on the
  // observed value instead of updatedAt. updatedAt is TIMESTAMP(3) (millisecond
  // precision), so two writes in the same millisecond produce an identical
  // timestamp and silently defeat the CAS; an integer counter cannot collide.
  version Int @default(0)

  lodge            Lodge?                @relation(fields: [lodgeId], references: [id], onDelete: Restrict)
  convertedBooking Booking?              @relation("BookingRequestConvertedBooking", fields: [convertedBookingId], references: [id], onDelete: SetNull)
  heldBooking      Booking?              @relation("BookingRequestHeldBooking", fields: [heldBookingId], references: [id], onDelete: SetNull)
  acceptedQuote    BookingRequestQuote?  @relation("BookingRequestAcceptedQuote", fields: [acceptedQuoteId], references: [id], onDelete: SetNull)
  quotes           BookingRequestQuote[]
  paymentLinks     PaymentLink[]

  @@index([status, createdAt])
  @@index([contactEmail])
  @@index([verificationTokenExpiresAt])
  @@index([status, reviewedAt])
  @@index([pricedByMemberId])
  @@index([reviewedByMemberId])
  @@index([heldBookingId])
  @@index([acceptedQuoteId])
}

// Versioned public booking request quotes. The raw response token is emailed
// once; only its SHA-256 hash is stored here.
model BookingRequestQuote {
  id                     String                    @id @default(cuid())
  bookingRequestId       String
  version                Int
  status                 BookingRequestQuoteStatus @default(DRAFT)
  pricingMode            BookingRequestPricingMode
  options                Json
  message                String?                   @db.VarChar(2000)
  responseTokenHash      String?                   @unique
  responseTokenExpiresAt DateTime?
  sentAt                 DateTime?
  reminderSentAt         DateTime?
  supersededAt           DateTime?
  acceptedAt             DateTime?
  cancelledAt            DateTime?
  createdByMemberId      String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  bookingRequest    BookingRequest  @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  acceptedByRequest BookingRequest? @relation("BookingRequestAcceptedQuote")

  @@unique([bookingRequestId, version])
  @@index([bookingRequestId, status])
  @@index([responseTokenExpiresAt])
  @@index([createdByMemberId])
}

// Tokenised public payment links (SHA-256 hash only; raw token is emailed once).
model PaymentLink {
  id               String    @id @default(cuid())
  bookingId        String
  bookingRequestId String?
  tokenHash        String    @unique
  expiresAt        DateTime
  usedAt           DateTime?
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  booking        Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingRequest BookingRequest? @relation(fields: [bookingRequestId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([bookingRequestId])
  @@index([expiresAt])
}

// Admin-controlled settings for the public booking request flow (single row).
model BookingRequestSettings {
  id                               String   @id @default("default")
  showPricingToNonMembers          Boolean  @default(false)
  quoteResponseTtlDays             Int      @default(14)
  quoteReminderLeadDays            Int      @default(3)
  // Soft link for the phase-7 singleton-to-per-lodge conversion
  // (docs/multi-lodge/implementation-plan.md); unused by runtime reads today.
  lodgeId                          String?
  // School attendee confirmation cadence (#1101): first prompt this many
  // days before check-in, then a reminder every N days until confirmed.
  attendeeConfirmationLeadDays     Int      @default(14)
  attendeeConfirmationReminderDays Int      @default(3)
  updatedByMemberId                String?
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt

  @@index([updatedByMemberId])
}

// ---------------------------------------------------------------------------
// Bed Allocation
// ---------------------------------------------------------------------------

model LodgeRoom {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(100)
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  notes     String?  @db.VarChar(500)
  lodgeId   String   @default(dbgenerated("default_lodge_id()"))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  beds                LodgeBed[]
  allocations         BedAllocation[]
  requestedByBookings Booking[]       @relation("BookingRequestedRoom")
  lodge               Lodge           @relation(fields: [lodgeId], references: [id], onDelete: Restrict)

  // Per-lodge name uniqueness. lodgeId is NOT NULL (migration 20260708001100),
  // so [lodgeId, name] is exact per lodge; no null-lodge rows remain.
  @@unique([lodgeId, name])
  @@index([active, sortOrder])
  @@index([lodgeId])
}

model Locker {
  id                  String   @id @default(cuid())
  name                String   @db.VarChar(200)
  allocatedToMemberId String?
  lodgeId             String   @default(dbgenerated("default_lodge_id()"))
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  allocatedTo Member? @relation("LockerAllocatedMember", fields: [allocatedToMemberId], references: [id], onDelete: SetNull)
  lodge       Lodge   @relation(fields: [lodgeId], references: [id], onDelete: Restrict)

  // Re-scoped from global to per-lodge ahead of the contract release
  // (expand-safe; see LodgeRoom). lodgeId is NOT NULL (migration 20260708001100),
  // so [lodgeId, name] is exact per lodge; no null-lodge rows remain. App checks
  // stay case-insensitive.
  @@unique([lodgeId, name])
  @@index([allocatedToMemberId])
  @@index([lodgeId])
}

model LodgeBed {
  id        String   @id @default(cuid())
  roomId    String
  name      String   @db.VarChar(100)
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  // Bed type (#1675). Base capacity stays 1/bed/night; an active DOUBLE also
  // adds one partner-shared admission slot above the base figure (#1745).
  bedType   BedType  @default(SINGLE)
  // Optional pairing label within a room: at most two beds share a bunkGroup,
  // one BUNK_TOP and one BUNK_BOTTOM. Enforced in admin-bed-allocation.ts, not
  // by a DB constraint (a "<=2 per group, one of each type" rule can't be a
  // plain unique index, and partial indexes are out of scope for this change).
  bunkGroup String?  @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room        LodgeRoom       @relation(fields: [roomId], references: [id], onDelete: Restrict)
  allocations BedAllocation[]

  @@unique([roomId, name])
  @@unique([id, roomId])
  @@index([roomId, active, sortOrder])
}

model BedAllocation {
  id                 String              @id @default(cuid())
  bookingId          String
  bookingGuestId     String
  roomId             String
  bedId              String
  stayDate           DateTime            @db.Date
  source             BedAllocationSource @default(AUTO)
  approvedByMemberId String?
  approvedAt         DateTime?
  // Double-bed sharing (#1701): a DOUBLE bed may hold two occupants for a night
  // — one primary (isSecondOccupant=false) and one second occupant. All other
  // bed types stay 1/night. isSecondOccupant is part of the relaxed
  // @@unique([bedId, stayDate, isSecondOccupant]); the second-occupant row is
  // only ever created by an admin on the allocation board (auto never sets it).
  isSecondOccupant   Boolean             @default(false)
  // Denormalized copy of LodgeBed.bedType, set at allocation-create. A partial
  // unique index predicate cannot join to LodgeBed, so the "non-double beds are
  // capped at 1/night" guard needs the type on this row. Default SINGLE is a
  // safe failsafe: an unset/wrong value makes the partial index treat the row as
  // non-double and REJECT a second occupant — erring toward under-, never
  // over-occupancy. updateBedAllocationBed keeps it in sync on bed-type changes.
  bedType            BedType             @default(SINGLE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingGuest BookingGuest @relation(fields: [bookingGuestId], references: [id], onDelete: Cascade)
  room         LodgeRoom    @relation(fields: [roomId], references: [id], onDelete: Restrict)
  bed          LodgeBed     @relation(fields: [bedId, roomId], references: [id, roomId], onDelete: Restrict)
  approvedBy   Member?      @relation("BedAllocationApprover", fields: [approvedByMemberId], references: [id], onDelete: SetNull)

  // Relaxed from @@unique([bedId, stayDate]) for #1701: two rows may share a
  // bed-night only when they differ on isSecondOccupant (≤1 primary + ≤1 second
  // ⇒ ≤2 rows/bed-night). Non-DOUBLE beds are additionally capped at exactly 1
  // by the raw-SQL partial index in the same migration (see
  // prisma/partial-unique-indexes.tsv). Old code inserts isSecondOccupant=false,
  // so it still cannot double-book a bed.
  @@unique([bedId, stayDate, isSecondOccupant])
  @@unique([bookingGuestId, stayDate])
  @@index([bookingId])
  @@index([bookingGuestId])
  @@index([roomId])
  @@index([approvedByMemberId])
}

model BedAllocationSettings {
  id                    String   @id @default("default")
  autoAllocationEnabled Boolean  @default(true)
  // Soft link for the phase-7 singleton-to-per-lodge conversion
  // (docs/multi-lodge/implementation-plan.md); unused by runtime reads today.
  lodgeId               String?
  updatedByMemberId     String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([updatedByMemberId])
}

// Single-row ("default") club setting controlling which optional member fields
// are collected/displayed. Defaults are ON to preserve existing behaviour; a
// club can switch a field off to avoid collecting data it does not need
// (Privacy Act minimisation). Gates UI, onboarding/profile capture and CSV.
model MemberFieldsSettings {
  id                String   @id @default("default")
  showTitle         Boolean  @default(true)
  showGender        Boolean  @default(true)
  showOccupation    Boolean  @default(true)
  updatedByMemberId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([updatedByMemberId])
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------

model Payment {
  id                            String        @id @default(cuid())
  bookingId                     String        @unique
  amountCents                   Int
  source                        PaymentSource @default(STRIPE)
  reference                     String?
  stripePaymentIntentId         String?       @unique
  stripePaymentMethodId         String?
  stripeSetupIntentId           String?       @unique
  stripeCustomerId              String?
  xeroInvoiceId                 String?       @unique
  xeroInvoiceNumber             String?
  status                        PaymentStatus @default(PENDING)
  refundedAmountCents           Int           @default(0)
  changeFeeCents                Int           @default(0)
  additionalPaymentIntentId     String?       @unique
  additionalAmountCents         Int           @default(0)
  additionalPaymentStatus       String? // PENDING, SUCCEEDED, FAILED
  xeroRefundCreditNoteId        String? // Track Xero credit note to prevent duplicates
  creditAppliedCents            Int           @default(0) // Account credit applied to this booking
  internetBankingHoldSlots      Boolean       @default(false)
  internetBankingHoldUntil      DateTime?
  internetBankingHoldReleasedAt DateTime?
  createdAt                     DateTime      @default(now())
  updatedAt                     DateTime      @updatedAt

  // Relations
  booking            Booking                    @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  transactions       PaymentTransaction[]
  refunds            PaymentRefund[]
  recoveryOperations PaymentRecoveryOperation[]

  @@index([bookingId])
  @@index([source, status, createdAt])
  @@index([source, status, internetBankingHoldUntil])
  @@index([stripePaymentIntentId])
  @@index([additionalPaymentIntentId])
  @@index([status, createdAt])
}

model PaymentTransaction {
  id                    String                 @id @default(cuid())
  paymentId             String
  kind                  PaymentTransactionKind
  source                PaymentSource          @default(STRIPE)
  stripePaymentIntentId String?                @unique
  xeroInvoiceId         String?
  xeroInvoiceNumber     String?
  reference             String?
  amountCents           Int
  refundedAmountCents   Int                    @default(0)
  status                PaymentStatus          @default(PENDING)
  paymentMethodId       String?
  reason                String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  payment            Payment                    @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  refunds            PaymentRefund[]
  recoveryOperations PaymentRecoveryOperation[]

  @@index([paymentId, createdAt])
  @@index([paymentId, kind, createdAt])
  @@index([source, status, createdAt])
  @@index([xeroInvoiceId])
  @@index([reference])
  @@index([status, createdAt])
}

model PaymentRefund {
  id                     String    @id @default(cuid())
  paymentId              String
  paymentTransactionId   String?
  stripeRefundId         String    @unique
  stripeChargeId         String?
  stripePaymentIntentId  String?
  amountCents            Int
  currency               String    @default("nzd")
  status                 String    @default("succeeded")
  reason                 String?
  xeroRefundCreditNoteId String?
  stripeCreatedAt        DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  payment            Payment             @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  paymentTransaction PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id], onDelete: SetNull)

  @@index([paymentId, createdAt])
  @@index([paymentTransactionId])
  @@index([stripeChargeId])
  @@index([stripePaymentIntentId])
  @@index([status, createdAt])
}

// Shared sliding-window rate-limit counters (#1039 item 4). Replicas and
// blue/green slots must see one counter per limiter+key, so the counter lives
// in Postgres instead of process memory; the in-memory limiter remains only
// as a per-process fallback when the database is unreachable.
model RateLimitCounter {
  id      String   @id
  count   Int
  resetAt DateTime

  @@index([resetAt])
}

// #1211: cross-instance cooldown for repeat operational admin alerts. One row
// per alert key; the stale payment-recovery-queue alert atomically claims a
// fresh window here (conditional updateMany on the id, falling back to a
// unique-guarded create) before sending, so N app instances raise at most one
// alert per window instead of one per instance. No @updatedAt and no column
// default keeps the migration a plain CREATE TABLE and avoids the
// @updatedAt/DB-default deploy-drift trap.
model AlertCooldown {
  key           String   @id
  lastAlertedAt DateTime
}

model PaymentRecoveryOperation {
  id                   String                         @id @default(cuid())
  type                 PaymentRecoveryOperationType
  status               PaymentRecoveryOperationStatus @default(PENDING)
  bookingId            String
  paymentId            String
  paymentTransactionId String?
  paymentIntentId      String
  amountCents          Int
  // #1097: the per-transaction refund allocation frozen on first processing,
  // so retries re-request exactly the unfinished slices with their original
  // Stripe idempotency keys. Array of { paymentTransactionId, amountCents }.
  allocationPlan       Json?
  // #1152: the originating route's Stripe idempotency key prefix, so a
  // recovery replays the exact keys the route used — a refund that succeeded
  // on Stripe but was never recorded locally is replayed, not re-minted.
  stripeKeyPrefix      String?
  idempotencyKey       String                         @unique
  attempts             Int                            @default(0)
  nextRetryAt          DateTime?                      @default(now())
  lastError            String?                        @db.Text
  processingStartedAt  DateTime?
  succeededAt          DateTime?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  booking            Booking             @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  payment            Payment             @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  paymentTransaction PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([paymentId])
  @@index([paymentTransactionId])
  @@index([paymentIntentId])
  @@index([status, nextRetryAt, createdAt])
  @@index([type, status])
}

// ---------------------------------------------------------------------------
// Promo Codes
// ---------------------------------------------------------------------------

model PromoCode {
  id                           String            @id @default(cuid())
  code                         String            @unique
  description                  String?
  type                         PromoCodeType
  // Per-individual benefit amounts (apply to each eligible guest on the booking)
  valueCents                   Int? // Fixed amount off, per eligible guest
  percentOff                   Int? // Percentage off, applied per eligible guest
  freeNightsPerIndividual      Int? // Per-booking cap: max free nights applied to each eligible guest on a single booking
  lifetimeFreeNightsCap        Int? // Lifetime cap: max free nights any single member can claim from this code across all their bookings (null = no lifetime cap)
  fixedNightlyPriceCents       Int? // Fixed nightly price per eligible guest-night for FIXED_NIGHTLY_PRICE promos
  fixedNightlyMode             FixedNightlyMode?
  // Optional per-night value cap (FREE_NIGHTS and PERCENTAGE only): caps the discount applied to any single night
  maxNightlyValueCents         Int?
  // Per-booking limit: how many guests on a single booking the promo applies to (null = unlimited / all eligible guests)
  maxGuestsPerBooking          Int?
  // Overall usage caps
  maxRedemptionsTotal          Int? // Hard cap on redemptions across all members (null = unlimited)
  maxUniqueMembersTotal        Int? // Hard cap on distinct members who can ever redeem (null = unlimited)
  maxUsesPerMember             Int? // Cap on how many bookings one member can apply this code to (null = unlimited, 1 = single-use)
  currentRedemptions           Int               @default(0)
  validFrom                    DateTime?
  validUntil                   DateTime?
  bookingStartFrom             DateTime? // Gate by booking CHECK-IN date (separate from validFrom/validUntil)
  bookingStartUntil            DateTime? // Gate by booking CHECK-IN date (separate from validFrom/validUntil)
  membersOnly                  Boolean           @default(false) // Booker must be a member
  memberGuestsOnly             Boolean           @default(false) // Promo only applies to guest rows flagged as members
  assignedMembersOnlyOwnNights Boolean           @default(true) // Assigned members can only apply the promo to their own linked guest nights
  // Optional Xero coding for the discount line on the booking invoice. When set, the discount
  // posts to these codes (separately reportable in the P&L) instead of inheriting hut-fee codes.
  // If a Xero Item Code is set and that Item has an account mapped in Xero, the item's mapping
  // wins unless xeroAccountCode is also explicitly supplied (in which case it overrides).
  xeroItemCode                 String?
  xeroAccountCode              String?
  // Internal promos are auto-applied by the system (e.g. work party events).
  // They are hidden from all promo listings and rejected at manual code entry.
  internal                     Boolean           @default(false)
  active                       Boolean           @default(true)
  archivedAt                   DateTime?
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt

  // Relations
  redemptions    PromoRedemption[]
  lodges         PromoCodeLodge[]
  allocations    PromoRedemptionAllocation[]
  assignments    PromoCodeAssignment[]
  workPartyEvent WorkPartyEvent?

  @@index([code])
  @@index([active])
  @@index([archivedAt])
}

model PromoRedemption {
  id                   String   @id @default(cuid())
  promoCodeId          String
  bookingId            String   @unique
  memberId             String
  discountCents        Int
  priceAdjustmentCents Int      @default(0)
  freeNightsUsed       Int? // Number of guest-nights subsidised (full or partial) for FREE_NIGHTS promos
  eligibleGuestCount   Int? // Number of guests the promo applied to on this booking (for reporting)
  createdAt            DateTime @default(now())

  // Relations
  promoCode    PromoCode                    @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)
  booking      Booking                      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  member       Member                       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  allocations  PromoRedemptionAllocation[]
  guestTargets PromoRedemptionGuestTarget[]

  @@index([promoCodeId])
  @@index([memberId])
}

model PromoRedemptionAllocation {
  id                   String   @id @default(cuid())
  promoRedemptionId    String
  promoCodeId          String
  bookingId            String
  memberId             String
  discountCents        Int
  priceAdjustmentCents Int      @default(0)
  freeNightsUsed       Int      @default(0)
  createdAt            DateTime @default(now())

  // Relations
  promoRedemption PromoRedemption @relation(fields: [promoRedemptionId], references: [id], onDelete: Cascade)
  promoCode       PromoCode       @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)
  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  member          Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([promoRedemptionId, memberId])
  @@unique([promoCodeId, bookingId, memberId])
  @@index([promoCodeId])
  @@index([memberId])
  @@index([bookingId])
}

model PromoRedemptionGuestTarget {
  id                String   @id @default(cuid())
  promoRedemptionId String
  bookingId         String
  bookingGuestId    String
  createdAt         DateTime @default(now())

  promoRedemption PromoRedemption @relation(fields: [promoRedemptionId], references: [id], onDelete: Cascade)
  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingGuest    BookingGuest    @relation(fields: [bookingGuestId], references: [id], onDelete: Cascade)

  @@unique([promoRedemptionId, bookingGuestId])
  @@index([bookingId])
  @@index([bookingGuestId])
}

// Optional per-lodge promo restriction (ADR-001 resolved question 4). No rows
// = the promo is redeemable at every lodge (the club-wide default). Rows =
// redeemable only at the listed lodges, supporting "two of three lodges"
// restrictions. Redemption validation compares against the booking's lodge.
model PromoCodeLodge {
  id          String   @id @default(cuid())
  promoCodeId String
  lodgeId     String
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  lodge     Lodge     @relation(fields: [lodgeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, lodgeId])
  @@index([lodgeId])
}

model PromoCodeAssignment {
  id          String   @id @default(cuid())
  promoCodeId String
  memberId    String
  createdAt   DateTime @default(now())

  // Relations
  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, memberId])
  @@index([promoCodeId])
  @@index([memberId])
}

// ---------------------------------------------------------------------------
// Work Party (Working Bee) Events
// ---------------------------------------------------------------------------

// Admin-created working bee events. Each event owns an internal auto-applied
// PromoCode (type PERCENTAGE) so redemption tracking, pricing, Xero, the $0
// confirmation path, and bump cleanup all reuse the existing promo machinery.
// The discount applies only to guest nights within startDate..endDate
// (both inclusive, matching Season night semantics).
model WorkPartyEvent {
  id              String   @id @default(cuid())
  name            String   @db.VarChar(200)
  description     String?  @db.VarChar(1000)
  startDate       DateTime @db.Date
  endDate         DateTime @db.Date
  discountPercent Int      @default(100)
  active          Boolean  @default(true)
  promoCodeId     String   @unique
  // Lodge the working bee is held at (lodge-scoping contract, audited
  // 2026-07-03). Null = club-wide event bookable at any lodge (also the
  // pre-migration meaning of every existing row). When set, bookings
  // attending this event must be at this lodge, so the event's internal
  // promo cannot be redeemed against a stay at the other property.
  lodgeId         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)
  lodge     Lodge?    @relation(fields: [lodgeId], references: [id], onDelete: SetNull)

  @@index([active])
  @@index([startDate, endDate])
  @@index([lodgeId])
}

// ---------------------------------------------------------------------------
// Chore Roster
// ---------------------------------------------------------------------------

model ChoreTemplate {
  id                   String             @id @default(cuid())
  name                 String
  description          String?
  recommendedPeopleMin Int                @default(1)
  recommendedPeopleMax Int                @default(2)
  isEssential          Boolean            @default(false)
  ageRestriction       AgeRestriction     @default(ANY)
  conditionalNote      String?
  minAge               Int                @default(0)
  sortOrder            Int                @default(0)
  timeOfDay            ChoreTimeOfDay     @default(ANYTIME)
  frequencyMode        ChoreFrequencyMode @default(DAILY)
  frequencyDays        Int?
  frequencyDaysOfWeek  Int[]
  active               Boolean            @default(true)
  lodgeId              String             @default(dbgenerated("default_lodge_id()"))
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Relations
  assignments ChoreAssignment[]
  lodge       Lodge             @relation(fields: [lodgeId], references: [id], onDelete: Restrict)

  @@index([lodgeId])
}

model ChoreAssignment {
  id              String      @id @default(cuid())
  choreTemplateId String
  bookingId       String
  bookingGuestId  String?
  date            DateTime    @db.Date
  status          ChoreStatus @default(SUGGESTED)
  completedAt     DateTime?
  completedVia    String? // "KIOSK", "ADMIN", or legacy "GUEST_LINK"
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  choreTemplate ChoreTemplate @relation(fields: [choreTemplateId], references: [id], onDelete: Restrict)
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingGuest  BookingGuest? @relation(fields: [bookingGuestId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([bookingId])
  @@index([bookingGuestId])
  @@index([choreTemplateId])
}

// ---------------------------------------------------------------------------
// Cancellation Policy
// ---------------------------------------------------------------------------

model CancellationPolicy {
  id                     String   @id @default(cuid())
  daysBeforeStay         Int
  refundPercentage       Int // Card refund percentage
  creditRefundPercentage Int? // Credit refund percentage (null = same as refundPercentage)
  fixedFeeCents          Int      @default(0) // Fixed fee deducted from card refunds per tier
  creditFixedFeeCents    Int? // Fixed fee deducted from credit refunds per tier (null = same as fixedFeeCents)
  // Null = club-wide default tier. Rows with a lodgeId are that lodge's
  // override set and replace (never merge with) the club-wide tiers
  // (ADR-001 resolved question 3). Permanently nullable.
  lodgeId                String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  lodge Lodge? @relation(fields: [lodgeId], references: [id], onDelete: Restrict)

  // Tier uniqueness is per partition: [lodgeId, daysBeforeStay]. PostgreSQL
  // treats nulls as distinct here, so this alone does not enforce uniqueness
  // within the club-wide (null lodgeId) partition. That partition is guarded
  // by the raw-SQL partial unique index
  // CancellationPolicy_clubwide_daysBeforeStay_unique (WHERE "lodgeId" IS
  // NULL, migration 20260709000100) — Prisma cannot express it here, and
  // `prisma migrate diff` does not surface it, so keep the migration and
  // this comment in sync. The admin route additionally replaces the
  // partition inside a Serializable transaction.
  @@unique([lodgeId, daysBeforeStay])
  @@index([lodgeId])
}

// ---------------------------------------------------------------------------
// Booking Periods (date-specific policy overrides, e.g. school holidays)
// ---------------------------------------------------------------------------

model BookingPeriod {
  id                   String   @id @default(cuid())
  name                 String // e.g. "School Holidays Jul 2026"
  startDate            DateTime @db.Date
  endDate              DateTime @db.Date
  nonMemberHoldEnabled Boolean  @default(true)
  nonMemberHoldDays    Int      @default(7)
  cancellationRules    Json // Array of {daysBeforeStay: number, refundPercentage: number}
  active               Boolean  @default(true)
  // Null = applies club-wide; a lodgeId scopes the period to that lodge
  // (ADR-001 resolved question 3). Permanently nullable.
  lodgeId              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  lodge Lodge? @relation(fields: [lodgeId], references: [id], onDelete: Restrict)

  @@index([startDate, endDate])
  @@index([lodgeId])
}

// ---------------------------------------------------------------------------
// Booking Defaults (global settings, single row)
// ---------------------------------------------------------------------------

// Cross-lodge waitlist queue order (ADR-004, owner decision 1): per
// candidate, OWN_LODGE_FIRST considers their own-lodge chance before any
// cross-lodge opt-in; across candidates the pass runs in club-wide join
// order (owner-accepted, #1566 — see ADR-004 implementation notes), so a
// freed lodge's queue is not necessarily exhausted first. MERGED ranks
// everyone eligible purely by when they joined. Club-wide policy.
enum WaitlistCrossLodgeOrder {
  OWN_LODGE_FIRST
  MERGED
}

model BookingDefaults {
  id                      String                  @id @default("default")
  nonMemberHoldEnabled    Boolean                 @default(true)
  nonMemberHoldDays       Int                     @default(7)
  waitlistCrossLodgeOrder WaitlistCrossLodgeOrder @default(OWN_LODGE_FIRST)
  // Soft link for the phase-7 singleton-to-per-lodge conversion
  // (docs/multi-lodge/implementation-plan.md); unused by runtime reads today.
  lodgeId                 String?
}

// Alternate lodges a waitlisted member would also accept (ADR-004). The
// entry itself stays bound to Booking.lodgeId — these rows only widen what
// the waitlist processor may offer. Rows are deleted with their booking.
model BookingWaitlistAlternateLodge {
  id        String   @id @default(cuid())
  bookingId String
  lodgeId   String
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  lodge   Lodge   @relation("WaitlistAlternateLodge", fields: [lodgeId], references: [id], onDelete: Cascade)

  @@unique([bookingId, lodgeId])
  @@index([lodgeId])
}

// ---------------------------------------------------------------------------
// Minimum Stay Policies
// ---------------------------------------------------------------------------

model MinimumStayPolicy {
  id            String   @id @default(cuid())
  name          String // e.g. "Winter Saturday Minimum Stay"
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  triggerDays   Int[] // Days of week: 0=Sunday, 1=Monday, ..., 6=Saturday
  minimumNights Int
  active        Boolean  @default(true)
  // Null = applies club-wide; a lodgeId scopes the policy to that lodge
  // (ADR-001 resolved question 3). Permanently nullable.
  lodgeId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lodge Lodge? @relation(fields: [lodgeId], references: [id], onDelete: Restrict)

  @@index([startDate, endDate])
  @@index([active])
  @@index([lodgeId])
}

// ---------------------------------------------------------------------------
// Xero OAuth Token (single row)
// ---------------------------------------------------------------------------

model XeroToken {
  id                     String    @id @default(cuid())
  accessToken            String
  refreshToken           String
  expiresAt              DateTime
  tenantId               String?
  refreshInProgressUntil DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// Finance Snapshot Storage
// ---------------------------------------------------------------------------

model FinanceSyncRun {
  id                  String                         @id @default(cuid())
  workflow            String
  trigger             FinanceSyncRunTrigger
  status              FinanceSyncRunStatus           @default(RUNNING)
  startedAt           DateTime                       @default(now())
  completedAt         DateTime?
  snapshotCount       Int                            @default(0)
  totalRowCount       Int                            @default(0)
  xeroTenantId        String?
  requestedByMemberId String?
  resultSummary       Json?
  errorSummary        String?
  errorDetails        Json?
  metadata            Json?
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt
  snapshots           FinanceSnapshot[]
  monthlyBalances     FinanceAccountMonthlyBalance[]

  @@index([workflow, startedAt])
  @@index([status, startedAt])
  @@index([trigger, startedAt])
}

model FinanceSnapshot {
  id              String              @id @default(cuid())
  snapshotType    FinanceSnapshotType
  scope           String              @default("default")
  asOfDate        DateTime            @db.Date
  periodStart     DateTime?           @db.Date
  periodEnd       DateTime?           @db.Date
  rowCount        Int                 @default(0)
  currency        String?
  sourceUpdatedAt DateTime?
  payload         Json
  syncRunId       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  syncRun         FinanceSyncRun?     @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  @@unique([snapshotType, scope, asOfDate], map: "FinanceSnapshot_snapshotType_scope_asOfDate_key")
  @@index([snapshotType, asOfDate])
  @@index([scope, asOfDate])
  @@index([syncRunId])
}

// One row per (statement kind, month, Xero account code): the monthly finance
// fact table the dashboard reads. PROFIT_AND_LOSS rows hold the month's net
// activity for a revenue/expense account; BALANCE_SHEET rows hold the closing
// month-end position for an asset/liability/equity account. Rows are replaced
// idempotently from multi-period Xero reports (12 months per sync), so late
// edits in Xero self-heal for a year back; older months come from backfill.
model FinanceAccountMonthlyBalance {
  id            String                      @id @default(cuid())
  statementKind FinanceMonthlyStatementKind
  scope         String                      @default("default")
  // Always the first day of the month, stored as an NZ date-only value.
  month         DateTime                    @db.Date
  // Normalized upper-case Xero GL code (matches FinanceReportCategoryMapping).
  accountCode   String                      @db.VarChar(40)
  accountId     String?
  accountName   String?                     @db.VarChar(200)
  // Xero account type (SALES, EXPENSE, BANK, CURRLIAB, ...) and class
  // (REVENUE | EXPENSE | ASSET | LIABILITY | EQUITY) from the chart of accounts.
  accountType   String?                     @db.VarChar(40)
  accountClass  String?                     @db.VarChar(20)
  amountCents   Int
  currency      String?                     @db.VarChar(8)
  // True while the month is still in progress (amounts are month-to-date);
  // flipped false by the first sync after month end.
  isProvisional Boolean                     @default(false)
  sourceReport  String                      @db.VarChar(60)
  syncRunId     String?
  syncedAt      DateTime                    @default(now())
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  syncRun       FinanceSyncRun?             @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  @@unique([statementKind, scope, month, accountCode])
  @@index([statementKind, month])
  @@index([accountCode, month])
  @@index([syncRunId])
}

model FinanceReportCategory {
  id        String                         @id @default(cuid())
  kind      FinanceReportCategoryKind
  name      String                         @db.VarChar(120)
  // Optional free-text sub-heading used to group categories into labelled
  // sub-sections (with sub-totals) in the finance dashboard.
  subtype   String?                        @db.VarChar(120)
  sortOrder Int                            @default(0)
  archived  Boolean                        @default(false)
  createdAt DateTime                       @default(now())
  updatedAt DateTime                       @updatedAt
  mappings  FinanceReportCategoryMapping[]

  @@unique([kind, name])
  @@index([kind, archived, sortOrder])
}

model FinanceReportCategoryMapping {
  id           String                @id @default(cuid())
  categoryId   String
  accountCode  String?               @db.VarChar(40)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  category     FinanceReportCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([accountCode])
}

// ---------------------------------------------------------------------------
// Xero Reconciliation Ledger
// ---------------------------------------------------------------------------

model XeroSyncOperation {
  id                     String    @id @default(cuid())
  direction              String
  entityType             String
  operationType          String
  localModel             String?
  localId                String?
  status                 String
  idempotencyKey         String?
  correlationKey         String?
  attemptCount           Int       @default(1)
  replayable             Boolean   @default(true)
  lastErrorCode          String?
  lastErrorMessage       String?
  requestPayload         Json?
  // Denormalized copy of the outbox discriminator, captured once at enqueue in
  // `startXeroSyncOperation` and never updated afterward (#1271, item 3 of
  // #1208). Dispatch reads queueType from `requestPayload` (not this column),
  // BEFORE handlers may overwrite `requestPayload` -- so after dispatch this
  // column can diverge from the payload (some handlers, e.g. the booking-invoice
  // create/update, rewrite requestPayload wholesale and drop queueType). That is
  // expected and safe: the pending-outbox scan (processQueuedXeroOutboxOperations,
  // #1272) filters on this column only for rows still awaiting dispatch (PENDING /
  // WAITING_PAYMENT), where it faithfully mirrors the enqueue-time queueType, so
  // post-dispatch divergence is never observed. Because that scan depends on it,
  // the column MUST remain immutable after enqueue. Null for REQUEUE, BACKFILL,
  // inbound, and any other row enqueued with no queueType.
  queueType              String?
  responsePayload        Json?
  xeroObjectType         String?
  xeroObjectId           String?
  xeroObjectNumber       String?
  xeroObjectUrl          String?
  createdByMemberId      String?
  startedAt              DateTime?
  completedAt            DateTime?
  // Operator override: a failed operation that was resolved directly in Xero.
  // When set, the operation is excluded from the active-failure overview and the
  // stuck-state dashboard count.
  manuallyResolvedAt     DateTime?
  manuallyResolvedReason String?
  manuallyResolvedById   String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([direction, status, createdAt])
  @@index([entityType, status, createdAt])
  @@index([queueType, status, createdAt])
  @@index([localModel, localId, createdAt])
  // No FULL @@unique on correlationKey/idempotencyKey (#1234 invariant (c)(1)
  // still holds: the same key legitimately recurs across rows over time -- a
  // terminal-status row from attempt 1 plus a fresh PENDING re-enqueue). The
  // #1234 rationale points (2)/(3) are superseded by #1354 (owner-approved,
  // #1375 sitting item 10): a raw PARTIAL unique index
  // "XeroSyncOperation_active_correlationKey_unique" ON (correlationKey)
  // WHERE correlationKey IS NOT NULL AND status IN
  // ('PENDING','RUNNING','WAITING_PAYMENT') lives in migration
  // 20260706040000 -- prisma cannot model it here, but `prisma migrate diff`
  // tolerates raw partial indexes (precedent: Member_email_login_unique), so
  // the drift check stays green. The findFirst dedup in the enqueue paths
  // remains the fast path; startXeroSyncOperation resolves a lost concurrent
  // race by catching the unique violation and returning the winner's active
  // row.
  @@index([correlationKey])
  @@index([idempotencyKey])
  @@index([xeroObjectType, xeroObjectId])
  @@index([status, manuallyResolvedAt])
}

// A member has at most one ACTIVE ENTRANCE_FEE_INVOICE link (#1886, F21),
// backstopped by a raw partial unique index
// (XeroObjectLink_entrance_fee_active_unique — see
// prisma/partial-unique-indexes.tsv; Prisma cannot express partial indexes).
// The composite @@unique below still allows multiple ACTIVE rows with
// different xeroObjectId, so the partial index closes that gap for the
// entrance-fee role. The primary concurrency guard is the member-scoped Xero
// mint idempotency key in xero-entrance-fee-invoices.ts (concurrent mints
// converge on one invoice, mirroring the F7/#1355 contact pattern); this index
// is the DB-level last line of defence.
model XeroObjectLink {
  id               String   @id @default(cuid())
  localModel       String
  localId          String
  xeroObjectType   String
  xeroObjectId     String
  xeroObjectNumber String?
  xeroObjectUrl    String?
  role             String
  active           Boolean  @default(true)
  metadata         Json?
