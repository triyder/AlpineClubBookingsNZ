// Declared Partner/Husband/Wife relationship between two ADULT members
// (#1742). Symmetric and consent-based: stored as a canonical ordered pair
// (memberAId < memberBId, DB CHECK constraint — which also blocks
// self-partnering). Lifecycle is PENDING -> CONFIRMED; a declined, withdrawn,
// or dissolved link is hard-deleted (history lives in the audit log) so the
// pair can re-form later without tripping the pair-unique constraint.
// At most one CONFIRMED partner per member: enforced in the service layer
// under pg_advisory_xact_lock and backstopped by two raw partial unique
// indexes (MemberPartnerLink_memberA/B_confirmed_unique — see
// prisma/partial-unique-indexes.tsv; Prisma cannot express partial indexes).
// This link is the eligibility signal for double-bed shared occupancy (#1741).
model MemberPartnerLink {
  id                  String    @id @default(cuid())
  memberAId           String
  memberBId           String
  status              String    @default("PENDING") // PENDING | CONFIRMED
  // Member who initiated the request; null when an admin assigned the link
  // directly. For one-step family-admin creation this is the family admin.
  initiatedByMemberId String?
  // Member who consented (accepted the request or claimed the invite token);
  // null while PENDING and for admin-assigned links.
  confirmedByMemberId String?
  // Admin who directly assigned the link (CONFIRMED immediately, no consent
  // round-trip); null for member-initiated links.
  assignedByAdminId   String?
  confirmedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  memberA         Member  @relation("PartnerLinkMemberA", fields: [memberAId], references: [id], onDelete: Cascade)
  memberB         Member  @relation("PartnerLinkMemberB", fields: [memberBId], references: [id], onDelete: Cascade)
  initiatedBy     Member? @relation("PartnerLinkInitiatedBy", fields: [initiatedByMemberId], references: [id], onDelete: SetNull)
  confirmedBy     Member? @relation("PartnerLinkConfirmedBy", fields: [confirmedByMemberId], references: [id], onDelete: SetNull)
  assignedByAdmin Member? @relation("PartnerLinkAssignedByAdmin", fields: [assignedByAdminId], references: [id], onDelete: SetNull)

  @@unique([memberAId, memberBId])
  @@index([memberBId])
  @@index([status])
  @@index([initiatedByMemberId])
  @@index([confirmedByMemberId])
  @@index([assignedByAdminId])
}

