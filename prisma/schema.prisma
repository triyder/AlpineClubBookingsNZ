  eventId     String   @unique
  source      String // "stripe" or "xero"
  eventType   String
  processedAt DateTime @default(now())

  @@index([source])
}

// ---------------------------------------------------------------------------
// Webhook Delivery Monitoring (OBS-08)
// ---------------------------------------------------------------------------

model WebhookLog {
  id         String   @id @default(cuid())
  source     String // "stripe" or "xero"
  eventType  String
  eventId    String
  status     String // "success" or "failure"
  durationMs Int
  error      String?
  createdAt  DateTime @default(now())

  @@index([source])
  @@index([createdAt])
  @@index([source, createdAt])
}

// ---------------------------------------------------------------------------
// Audit Log (tracks sensitive admin and system actions)
// ---------------------------------------------------------------------------

model AuditLog {
  id              String    @id @default(cuid())
  action          String
  memberId        String?
  targetId        String?
  details         String?
  ipAddress       String?
  createdAt       DateTime  @default(now())
  actorMemberId   String?
  subjectMemberId String?
  entityType      String?
  entityId        String?
  category        String?
  severity        String?
  outcome         String?
  summary         String?
  metadata        Json?
  requestId       String?
  userAgent       String?
  retentionClass  String?
  expiresAt       DateTime?
  archivedAt      DateTime?

  @@index([action])
  @@index([memberId])
  @@index([createdAt])
  @@index([memberId, createdAt])
  @@index([targetId, createdAt])
  @@index([actorMemberId, createdAt])
  @@index([subjectMemberId, createdAt])
  @@index([entityType, entityId])
  @@index([category, createdAt])
  @@index([expiresAt])
  @@index([retentionClass, expiresAt])
  @@index([archivedAt])
}

// ---------------------------------------------------------------------------
// Booking Modifications (history of changes to bookings)
// ---------------------------------------------------------------------------

model BookingModification {
  id               String   @id @default(cuid())
  bookingId        String
  memberId         String
  modificationType String // DATE_CHANGE | GUEST_ADD | GUEST_REMOVE | EXTEND_STAY
  previousData     Json // snapshot of changed fields before
  newData          Json // snapshot of changed fields after
  priceDiffCents   Int      @default(0) // positive = owes more, negative = refund
  changeFeeCents   Int      @default(0) // late-notice fee charged
  createdAt        DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([memberId])
}

// ---------------------------------------------------------------------------
// Email Delivery Tracking (N-10)
// ---------------------------------------------------------------------------

enum EmailLogStatus {
  QUEUED
  SENT
  FAILED
  BOUNCED
}

enum EmailSuppressionReason {
  BOUNCE
  COMPLAINT
}

model EmailLog {
  id            String         @id @default(cuid())
  to            String
  subject       String
  templateName  String
  htmlBody      String? // Stored only for retry-safe templates; token-bearing templates are redacted
  status        EmailLogStatus @default(QUEUED)
  errorMessage  String?
  attempts      Int            @default(1)
  lastAttemptAt DateTime       @default(now())
  sentAt        DateTime?
  messageId     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([to])
  @@index([status])
  @@index([createdAt])
  @@index([status, attempts])
  @@index([templateName, status, createdAt])
}

model EmailSuppression {
  id                        String                 @id @default(cuid())
  email                     String                 @unique
  reason                    EmailSuppressionReason
  eventCount                Int                    @default(1)
  suppressedAt              DateTime?
  lastEventAt               DateTime               @default(now())
  lastEventType             String
  lastBounceType            String?
  lastBounceSubType         String?
  lastComplaintFeedbackType String?
  lastSesMessageId          String?
  clearedAt                 DateTime?
  clearedById               String?
  clearReason               String?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  @@index([suppressedAt])
  @@index([clearedAt])
  @@index([reason, suppressedAt])
  @@index([lastEventAt])
}

model IssueReport {
  id                String   @id @default(cuid())
  memberId          String
  pageUrl           String   @db.VarChar(2048)
  pageTitle         String?  @db.VarChar(300)
  description       String   @db.Text
  screenshotDataUrl String?  @db.Text
  browserInfo       String?  @db.Text
  createdAt         DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, createdAt])
  @@index([createdAt])
}

