  contactEmailMode     ContactEmailMode @default(ROLE)
  contactEmailOverride String?
  isActive           Boolean  @default(true)
  assignedByMemberId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  member        Member        @relation("CommitteeAssignmentMember", fields: [memberId], references: [id], onDelete: Cascade)
  committeeRole CommitteeRole @relation(fields: [committeeRoleId], references: [id], onDelete: Restrict)
  assignedBy    Member?       @relation("CommitteeAssignmentAssignedBy", fields: [assignedByMemberId], references: [id], onDelete: SetNull)

  @@unique([memberId, committeeRoleId])
  @@index([committeeRoleId])
  @@index([memberId])
  @@index([isActive, published, sortOrder])
  @@index([assignedByMemberId])
}

// ---------------------------------------------------------------------------
// Lodge Induction Sign-Off (induction checklist + nomination eligibility gate)
//
// A versioned competency checklist (sourced from the club's 2008 Induction
// Sheet) recorded per member. A member becomes eligible to nominate new members
// only once their own induction is signed off AND they meet a minimum
// membership tenure and minimum nights stayed (admin-configurable). Existing
// members who joined before the gate's effective date are grandfathered.
// ---------------------------------------------------------------------------

enum InductionStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  VOIDED
}

enum InductionKind {
  NEW_MEMBER
  HUT_LEADER
  YOUTH_TO_FULL
  RE_INDUCTION
}

enum InductionSignerRole {
  NOMINATOR
  HUT_LEADER
  ADMIN
}

enum InductionCompletionSource {
  SIGN_OFFS
  ADMIN_OVERRIDE
}

enum InductionSectionPriority {
  EMERGENCY
  SECURITY
  STARTUP
  SHUTDOWN
  GENERAL
}

model InductionChecklistTemplate {
  id          String        @id @default(cuid())
  name        String
  version     String
  kind        InductionKind @default(NEW_MEMBER)
  sourceLabel String?
  isActive    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  sections   InductionChecklistSection[]
  inductions MemberInduction[]

  @@index([isActive])
  @@index([kind, isActive])
}

model InductionChecklistSection {
  id          String                   @id @default(cuid())
  templateId  String
  title       String
  description String?
  priority    InductionSectionPriority
  sortOrder   Int                      @default(0)

  template InductionChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items    InductionChecklistItem[]

  @@index([templateId])
}

model InductionChecklistItem {
  id                    String  @id @default(cuid())
  sectionId             String
  label                 String
  competencyPrompt      String?
  notesPrompt           String?
  isMandatory           Boolean @default(false)
  requiresDemonstration Boolean @default(false)
  sortOrder             Int     @default(0)
  legacySourceText      String?

  section InductionChecklistSection   @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

model MemberInduction {
  id                 String                     @id @default(cuid())
  memberId           String
  templateId         String
  applicationId      String?                    @unique
  kind               InductionKind              @default(NEW_MEMBER)
  status             InductionStatus            @default(IN_PROGRESS)
  requiredSignOffs   Int                        @default(2)
  inductionDate      DateTime?
  completedAt        DateTime?
  completionSource   InductionCompletionSource?
  finalComments      String?
  voidedReason       String?
  createdByMemberId  String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  member          Member                          @relation("MemberInductions", fields: [memberId], references: [id], onDelete: Cascade)
  template        InductionChecklistTemplate      @relation(fields: [templateId], references: [id], onDelete: Restrict)
  application     MemberApplication?              @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  signOffs        MemberInductionSignOff[]
  assignedSigners MemberInductionAssignedSigner[]

  @@index([memberId])
  @@index([templateId])
  @@index([status])
  @@index([kind])
}

model MemberInductionSignOff {
  id                  String              @id @default(cuid())
  inductionId         String
  signerMemberId      String?
  signerName          String
  signerRole          InductionSignerRole
  declarationAccepted Boolean             @default(false)
  comments            String?
  signedAt            DateTime            @default(now())

  induction MemberInduction @relation(fields: [inductionId], references: [id], onDelete: Cascade)
  signer    Member?         @relation("InductionSignOffSigner", fields: [signerMemberId], references: [id], onDelete: SetNull)

  @@unique([inductionId, signerMemberId])
  @@index([inductionId])
  @@index([signerMemberId])
}

model MemberInductionAssignedSigner {
  id          String    @id @default(cuid())
  inductionId String
  memberId    String
  emailSentAt DateTime?
  createdAt   DateTime  @default(now())

  induction MemberInduction @relation(fields: [inductionId], references: [id], onDelete: Cascade)
  member    Member          @relation("AssignedInductionSigners", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([inductionId, memberId])
  @@index([inductionId])
  @@index([memberId])
}

model MembershipNominationSettings {
  id                      String    @id @default("default")
  gateEnabled             Boolean   @default(false)
  minimumMembershipMonths Int       @default(12)
  minimumNights           Int       @default(6)
  requiredSignOffs        Int       @default(2)
  gateEffectiveFrom       DateTime?
  updatedByMemberId       String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

// Admin-configurable settings for the booking lockout that blocks members with
// an unpaid annual subscription. Single-row table (id = "default"), same
// pattern as MembershipNominationSettings. The subscription detection codes
// (account code / item code) are NOT stored here; they remain in the
// XeroAccountMapping "subscriptionIncome" row so there is a single source of
// truth shared with the Xero mappings panel.
model MembershipLockoutSettings {
  id                            String   @id @default("default")
  // Master toggle. When false, no booking is blocked for an unpaid subscription.
  enabled                       Boolean  @default(true)
  // Membership financial year-end month (1-12). Null = follow the connected
  // Xero organisation's accounting financial year. A value overrides it when the
  // membership subscription year differs from the accounting year.
  financialYearEndMonthOverride Int?
  // When true, an invoice whose reference/description text reads like a
  // membership subscription also counts, in addition to account/item code.
  textFallbackEnabled           Boolean  @default(true)
  updatedByMemberId             String?
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Lobby TV Display (docs/lobby-display/design.md, fork epic #25)
// ---------------------------------------------------------------------------

// A page layout (ADR-003 §1, LTV-024): the structural HTML body with named
// areas/slots, a default CSS block, and per-slot metadata. All layouts share a
// fixed header and an editable footer (page furniture, not part of the body).
// `areas` is an ordered list of slot descriptors
// ({ key, description, kind: static|conditional|rotator, condition?,
// rotateSeconds?, children?, defaultContent }) validated app-side (LTV-027/030),
// exactly as the retired definition Json was.
model DisplayLayout {
  id          String   @id @default(cuid())
  key         String   @unique @db.VarChar(80)
  name        String   @db.VarChar(120)
  description String?
  bodyHtml    String   @db.Text
  defaultCss  String   @db.Text
  areas       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  templates DisplayTemplate[]
}

// A selectable display design (ADR-003 §1, LTV-024): built on a DisplayLayout,
// it fills each declared slot with content or an embedded module, layers CSS
// overrides on the layout default, and carries the footer content. It renders
// dynamically against whichever lodge its display is bound to; `slotContent`
// maps areaKey -> { html } or { module, options? }. A layout still referenced
// by a template cannot be deleted (Restrict).
model DisplayTemplate {
  id           String   @id @default(cuid())
  key          String   @unique @db.VarChar(80)
  name         String   @db.VarChar(120)
  layoutId     String
  slotContent  Json
  cssOverrides String   @db.Text
  footerHtml   String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  layout  DisplayLayout        @relation(fields: [layoutId], references: [id], onDelete: Restrict)
  devices LodgeDisplayDevice[]

  @@index([layoutId])
}

// A physical lobby display (TV/browser) paired to exactly one lodge. The raw
// display credential is never stored — only its hash (docs/TOKEN_HASHING.md);
// pairing codes are short-lived and single-use. Lifecycle: created → pairing
// (code active) → paired → revoked (docs/lobby-display/design.md §4).
// Deleting a bound template falls the device back to the club default
// (SetNull) rather than breaking the device.
model LodgeDisplayDevice {
  id                   String    @id @default(cuid())
  lodgeId              String
  name                 String    @db.VarChar(120)
  pairingCode          String?   @db.VarChar(16)
  pairingCodeExpiresAt DateTime?
  tokenHash            String?   @unique
  templateId           String?
  // Per-device state-poll cadence in seconds (LTV-039, issue #85; consolidates
  // #66). null = the client default (~60s). Clamped server-side to 15–600 on
  // read and write. The poll doubles as the device heartbeat, so this also
  // governs how often lastSeenAt refreshes.
  pollSeconds          Int?
  lastSeenAt           DateTime?
  revokedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  lodge    Lodge            @relation(fields: [lodgeId], references: [id], onDelete: Restrict)
  template DisplayTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([lodgeId])
  @@index([templateId])
}

// How guest names are reduced by the lobby display's privacy serialiser
// (fork issue #28, docs/lobby-display/design.md §10). Enforcement lives in
// src/lib/lodge-display-state.ts — the single choke point for what a public
// screen may show. Minors are never individually named at ANY level.
enum DisplayNameGranularity {
  FULL_NAME
  FIRST_NAME_SURNAME_INITIAL
  FIRST_NAME_ONLY
  COUNTS_ONLY
}
