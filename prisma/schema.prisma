// BOOKING_RESTRICTION: a member with any rows of this kind may book ONLY the
// listed lodges. No rows = default-open (every active member books every
// active lodge) — the club-wide default that most members keep forever.
//
// STAFF: binds a lodge-operational account (shared kiosk login) to a lodge so
// its kiosk screens and PIN logins scope to that property. ADMIN access is
// club-wide and never expressed through this table.
enum LodgeAccessKind {
  BOOKING_RESTRICTION
  STAFF
}

model MemberLodgeAccess {
  id          String          @id @default(cuid())
  memberId    String
  lodgeId     String
  kind        LodgeAccessKind
  createdById String?
  createdAt   DateTime        @default(now())

  member    Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  lodge     Lodge   @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  createdBy Member? @relation("MemberLodgeAccessCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([memberId, lodgeId, kind])
  @@index([lodgeId])
  @@index([memberId, kind])
  @@index([createdById])
}

// ---------------------------------------------------------------------------
// Lodge Instructions (issue #710)
