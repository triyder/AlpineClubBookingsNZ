// ---------------------------------------------------------------------------
// Family Groups (links primary adult members for shared booking quick-add)
// ---------------------------------------------------------------------------

model FamilyGroup {
  id            String                   @id @default(cuid())
  name          String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  // @deprecated — legacy single-group FK; use memberships (FamilyGroupMember) instead
  legacyMembers Member[]                 @relation("FamilyGroupLegacy")
  memberships   FamilyGroupMember[]
  joinRequests  FamilyGroupJoinRequest[]
}

model FamilyGroupMember {
  id            String   @id @default(cuid())
  familyGroupId String
  memberId      String
  role          String   @default("MEMBER") // ADMIN or MEMBER (group admin can manage the group)
  joinedAt      DateTime @default(now())

  familyGroup FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  member      Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([familyGroupId, memberId])
  @@index([memberId])
  @@index([familyGroupId])
}

model FamilyGroupJoinRequest {
  id            String    @id @default(cuid())
  familyGroupId String
  requesterId   String
  type          String    @default("JOIN_REQUEST") // JOIN_REQUEST | ADULT_INVITE | CHILD_REQUEST | ADULT_REQUEST | REMOVAL_REQUEST
  status        String    @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?

  // For ADULT_INVITE: the member being invited
  invitedMemberId String?
  invitedMember   Member? @relation("FamilyGroupInvitedMember", fields: [invitedMemberId], references: [id])

  // For CHILD_REQUEST: child details submitted by parent
  childFirstName   String?
  childLastName    String?
  childDateOfBirth DateTime?

  // For ADULT_REQUEST: non-login adult details submitted by a family adult
  requestedFirstName   String?
  requestedLastName    String?
  requestedDateOfBirth DateTime?
  requestedEmail       String?

  // Set by admin when approving CHILD_REQUEST — links to existing member
  linkedMemberId String?
  linkedMember   Member? @relation("FamilyGroupLinkedMember", fields: [linkedMemberId], references: [id])

  // For REMOVAL_REQUEST: member to remove from the requested family group
  subjectMemberId String?
  subjectMember   Member? @relation("FamilyGroupSubjectMember", fields: [subjectMemberId], references: [id])

  requestNotes String?

  familyGroup FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  requester   Member      @relation("FamilyGroupRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([familyGroupId])
  @@index([requesterId])
  @@index([invitedMemberId])
  @@index([linkedMemberId])
  @@index([subjectMemberId])
  @@index([requestedEmail])
  @@index([status])
  @@index([type])
}

// ---------------------------------------------------------------------------
// Notification Preferences (N-08)
// ---------------------------------------------------------------------------

model NotificationPreference {
  id                      String   @id @default(cuid())
  memberId                String   @unique
  bookingConfirmation     Boolean  @default(true)
  bookingReminder         Boolean  @default(true)
  bookingBumped           Boolean  @default(true)
  bookingCancelled        Boolean  @default(true)
  bookingWaitlist         Boolean  @default(true)
  choreRoster             Boolean  @default(true)
  marketingEmails         Boolean  @default(false)
  adminNewBooking         Boolean  @default(true)
  adminPaymentFailure     Boolean  @default(true)
  adminPendingDeadline    Boolean  @default(true)
  adminBookingBumped      Boolean  @default(true)
  adminXeroSyncError      Boolean  @default(true)
  adminCapacityWarning    Boolean  @default(true)
  adminDailyDigest        Boolean  @default(true)
  adminWaitlistOffer      Boolean  @default(true)
  adminFamilyGroupRequest Boolean  @default(true)
  adminRefundRequest      Boolean  @default(true)
  adminIssueReport        Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Xero Account Mappings (XAM-01)
// ---------------------------------------------------------------------------

model XeroAccountMapping {
  id        String   @id @default(cuid())
  key       String   @unique // hutFeesIncome | hutFeeRefunds | stripeBankAccount | stripeFees | subscriptionIncome | hutFeeItem | hutFeeRefundItem | entranceFeeItem | entranceFeeAmountCents
  code      String? // null = not configured, use application default (GL account code or amount string)
  itemCode  String? // Xero Item Code — when set, Xero auto-fills account from Item config
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ---------------------------------------------------------------------------
// Xero Item Code Mappings — granular per age tier / season / member status
// ---------------------------------------------------------------------------

enum EntranceFeeCategory {
  ADULT
  YOUTH
  CHILD
  FAMILY
}

model XeroItemCodeMapping {
  id                  String               @id @default(cuid())
  category            String // "HUT_FEE" | "ENTRANCE_FEE"
  ageTier             AgeTier? // HUT_FEE only
  seasonType          SeasonType? // HUT_FEE only
  isMember            Boolean? // HUT_FEE only
  entranceFeeCategory EntranceFeeCategory? // ENTRANCE_FEE only
  itemCode            String? // Optional Xero Item Code
  amountCents         Int? // ENTRANCE_FEE only (per-category pricing)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([category, ageTier, seasonType, isMember])
  @@unique([category, entranceFeeCategory])
  @@index([category])
}

// ---------------------------------------------------------------------------
// Age Tier Settings (Issue 14 — configurable age group boundaries)
// ---------------------------------------------------------------------------

model AgeTierSetting {
  id                        String                            @id @default(cuid())
  tier                      AgeTier                           @unique
  minAge                    Int
  maxAge                    Int? // null for ADULT (no upper limit)
  label                     String // e.g. "Child (under 10)"
  xeroContactGroupId        String?
  xeroContactGroupName      String?
  xeroAcceptedContactGroups AgeTierXeroAcceptedContactGroup[]
  sortOrder                 Int                               @default(0)
  createdAt                 DateTime                          @default(now())
  updatedAt                 DateTime                          @updatedAt

  @@index([sortOrder])
}

model AgeTierXeroAcceptedContactGroup {
  id               String   @id @default(cuid())
  ageTierSettingId String
  groupId          String   @unique
  groupName        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ageTierSetting AgeTierSetting @relation(fields: [ageTierSettingId], references: [id], onDelete: Cascade)

  @@index([ageTierSettingId])
}

// ---------------------------------------------------------------------------
// Account Deletion Requests (F-COMP-04)
// ---------------------------------------------------------------------------

enum DeletionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model DeletionRequest {
  id         String                @id @default(cuid())
  memberId   String
  status     DeletionRequestStatus @default(PENDING)
  reason     String? // Optional free-text reason from member
  adminNote  String? // Note from admin on approve/reject
  reviewedBy String? // Admin member ID
  reviewedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Account Credits (Issue #37)
// ---------------------------------------------------------------------------

model MemberCredit {
  id                 String     @id @default(cuid())
  memberId           String
  amountCents        Int // Positive = credit added, negative = credit used
  type               CreditType
  description        String // Human-readable reason
  requestedById      String? // Admin who requested a manual adjustment
  approvedById       String? // Admin who approved a manual adjustment
  approvalRequestId  String?    @unique // Links approved manual adjustments to their request
  sourceBookingId    String? // Booking that generated the credit (cancellation)
  appliedToBookingId String? // Booking where credit was spent
  xeroCreditNoteId   String? // Linked Xero credit note ID
  createdAt          DateTime   @default(now())

  member           Member                        @relation(fields: [memberId], references: [id], onDelete: Restrict)
  requestedBy      Member?                       @relation("RequestedAdminCredits", fields: [requestedById], references: [id], onDelete: SetNull)
  approvedBy       Member?                       @relation("ApprovedAdminCredits", fields: [approvedById], references: [id], onDelete: SetNull)
  approvalRequest  AdminCreditAdjustmentRequest? @relation("ApprovedAdminCreditAdjustment", fields: [approvalRequestId], references: [id], onDelete: SetNull)
  sourceBooking    Booking?                      @relation("CreditSource", fields: [sourceBookingId], references: [id], onDelete: SetNull)
  appliedToBooking Booking?                      @relation("CreditApplied", fields: [appliedToBookingId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@index([requestedById])
  @@index([approvedById])
  @@index([sourceBookingId])
  @@index([appliedToBookingId])
}

model AdminCreditAdjustmentRequest {
  id             String                             @id @default(cuid())
  memberId       String
  amountCents    Int
  description    String
  idempotencyKey String
  status         AdminCreditAdjustmentRequestStatus @default(PENDING)
  requestedById  String
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime                           @default(now())
  updatedAt      DateTime                           @updatedAt

  member         Member        @relation("AdminCreditAdjustmentTarget", fields: [memberId], references: [id], onDelete: Restrict)
  requestedBy    Member        @relation("AdminCreditAdjustmentRequestsRequested", fields: [requestedById], references: [id])
  reviewedBy     Member?       @relation("AdminCreditAdjustmentRequestsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)
  approvedCredit MemberCredit? @relation("ApprovedAdminCreditAdjustment")

  @@unique([requestedById, idempotencyKey])
  @@index([memberId, status, createdAt])
  @@index([requestedById, createdAt])
  @@index([reviewedById, createdAt])
}

// ---------------------------------------------------------------------------
// Group Discount Settings (P5.1)
// ---------------------------------------------------------------------------

model GroupDiscountSetting {
  id           String   @id @default("default")
  minGroupSize Int      @default(5)
  summerOnly   Boolean  @default(true)
  enabled      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Refund Requests / Appeals (P5.4)
// ---------------------------------------------------------------------------

enum RefundRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model RefundRequest {
  id                   String              @id @default(cuid())
  bookingId            String
  memberId             String
  reason               String
  requestedAmountCents Int?
  status               RefundRequestStatus @default(PENDING)
  adminNotes           String?
  approvedAmountCents  Int?
  reviewedBy           String?
  reviewedAt           DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([memberId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Committee Members (public-facing committee page, admin-managed)
// ---------------------------------------------------------------------------

model CommitteeMember {
  id          String   @id @default(cuid())
  role        String // Position title (e.g. "President")
  name        String // Display name
  phone       String // Contact phone number
  email       String? // Optional email address
  contactKey  String?  @unique // Maps to /contact?recipient=key
  description String // Role description
  sortOrder   Int      @default(0) // Display order on public page
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
