// A physical lodge property. Every deployment has at least one row (seeded by
// migration/seed). Multi-lodge is core (ADR-005): the Lodges admin UI is always
// available (no module flag), and booking data scopes to this table. While
// exactly one active lodge exists the per-page lodge selectors auto-resolve to
// it (ADR-002 presentation rule); the vestigial ClubModuleSettings.multiLodge
// column is retired in a follow-up (#129).
model Lodge {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  active     Boolean  @default(true)
  // Durable default-lodge marker (#1656/#1627 option b): getDefaultLodgeId()
  // and the default_lodge_id() SQL function resolve the club default from this
  // flag instead of earliest-createdAt ordering (which inverts on TZ-skewed
  // seeds). At most one lodge is default, enforced by the partial unique index
  // "Lodge_isDefault_key" (WHERE "isDefault") created in migration
  // 20260709120000 — a raw partial index Prisma cannot express in-schema (same
  // pattern as XeroSyncOperation_active_correlationKey_unique). To change the
  // default, unset the current one and set the new one in a single transaction.
  isDefault  Boolean  @default(false)
  doorCode   String?  @db.VarChar(80)
  travelNote String?
  // Postal / physical address of the lodge, admin-editable (E3 #1929). Feeds the
  // {{lodge-address}} content placeholder and the public contact page's lodge block.
  // Nullable: fresh installs seed no address (the seed-account-defaults guard
  // keeps geography out of seeds); the additive migration backfills only the
  // existing default lodge with the historical hardcoded string.
  address    String?  @db.VarChar(300)
  // Per-lodge config glob for the lobby display's {{config:<key>}}
  // placeholders (docs/lobby-display/design.md §3, fork issue #26): free-form
  // string key/value pairs, validated at the admin edit surface. Null = none.
  displayConfig Json?
  // Per-lodge override of the lobby display name granularity (fork issue
  // #28, design.md §10). Null = the club-wide code default
  // (FIRST_NAME_SURNAME_INITIAL). Enum defined with the lobby-display
  // models at the end of this file.
  displayNameGranularity DisplayNameGranularity?
  // Committee notice board for the lobby display (fork issue #36): the one
  // deliberately AUTHORED display surface — free text, admin-edited,
  // rendered as text nodes only ({{config:<key>}} placeholders resolve
  // inside it). Null = no notice.
  displayNotice          String?  @db.VarChar(2000)
  // Per-lodge toggle: show guest phone numbers on this lodge's screens (kiosk +
  // lobby display), default OFF (#37/#124). Combined with the per-member opt-in
  // and an adults-only rule, enforced in the serving serialisers.
  showGuestPhonesOnScreens Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // lodgeId is nullable on these tables during the expand release
  // (docs/multi-lodge/implementation-plan.md phase 2); a contract release
  // enforces NOT NULL and per-lodge uniqueness once every writer sets it. The
  // policy tables (CancellationPolicy, BookingPeriod, MinimumStayPolicy) stay
  // permanently nullable: null rows are the club-wide defaults (ADR-001).
  rooms                    LodgeRoom[]
  lockers                  Locker[]
  seasons                  Season[]
  bookings                 Booking[]
  choreTemplates           ChoreTemplate[]
  cancellationPolicies     CancellationPolicy[]
  bookingPeriods           BookingPeriod[]
  minimumStayPolicies      MinimumStayPolicy[]
  hutLeaderAssignments     HutLeaderAssignment[]
  memberAccess             MemberLodgeAccess[]
  promoCodes               PromoCodeLodge[]
  waitlistOfferedBookings  Booking[]                       @relation("BookingWaitlistOfferedLodge")
  waitlistAlternateEntries BookingWaitlistAlternateLodge[] @relation("WaitlistAlternateLodge")
  workPartyEvents          WorkPartyEvent[]
  instructions             LodgeInstruction[]
  bookingRequests          BookingRequest[]
  displayDevices           LodgeDisplayDevice[]
}

