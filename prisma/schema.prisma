// ---------------------------------------------------------------------------
// Xero Item Code Mappings — granular per age tier / season / member status
// ---------------------------------------------------------------------------

enum EntranceFeeCategory {
  ADULT
  YOUTH
  CHILD
  FAMILY
}

model XeroItemCodeMapping {
  id                  String               @id @default(cuid())
  category            String // "HUT_FEE" | "ENTRANCE_FEE"
  ageTier             AgeTier? // HUT_FEE only
  seasonType          SeasonType? // HUT_FEE only
  // Legacy member/non-member key column (#1930, E4). Retained alongside the
  // new membershipTypeId key so day-one item-code resolution stays
  // byte-identical; E13 drops it and the old unique after a release soak.
  isMember            Boolean? // HUT_FEE only (legacy key, retained)
  // Membership-type key for HUT_FEE item codes (#1930, E4). Nullable ageTier
  // mirrors MembershipTypeSeasonRate: a per-tier type has one row per tier, a
  // flat type has a single NULL-ageTier row. A companion raw-SQL partial
  // unique index (WHERE "ageTier" IS NULL AND category = 'HUT_FEE') enforces
  // one flat row per (type, seasonType) and lives in the migration +
  // prisma/partial-unique-indexes.tsv.
  membershipTypeId    String? // HUT_FEE only
  entranceFeeCategory EntranceFeeCategory? // ENTRANCE_FEE only
  itemCode            String? // Optional Xero Item Code
  amountCents         Int? // ENTRANCE_FEE only (per-category pricing)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([category, ageTier, seasonType, isMember])
  // Explicit map: the Prisma default constraint name (68 bytes) exceeds
  // Postgres's 63-byte identifier limit and would be silently truncated,
  // drifting from the migration SQL (#1930, E4). The client API name is
  // unchanged (category_membershipTypeId_seasonType_ageTier).
  @@unique([category, membershipTypeId, seasonType, ageTier], map: "XeroItemCodeMapping_category_typeId_seasonType_ageTier_key")
  @@unique([category, entranceFeeCategory])
  @@index([category])
  @@index([membershipTypeId])
}

